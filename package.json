{
  "name": "carteakey.dev",
  "version": "2.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "build": "npm-run-all -s build:*",
    "build:11ty": "npx @11ty/eleventy",
    "build:css": "npx @tailwindcss/cli -i ./src/static/css/tailwind.css -o ./_site/css/tailwind.css --minify --postcss",
    "bench": "DEBUG=Eleventy:Benchmark* npx @11ty/eleventy",
    "watch": "npx @11ty/eleventy --watch",
    "serve": "npx @11ty/eleventy --serve",
    "start": "npm-run-all -p start:*",
    "start:11ty": "npx @11ty/eleventy --serve",
    "start:css": "npx @tailwindcss/cli -i ./src/static/css/tailwind.css -o ./_site/css/tailwind.css --watch --postcss",
    "debug": "DEBUG=* npx @11ty/eleventy",
    "metrics:merge-check": "node ./utils/check-engagement-merge.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/carteakey/carteakey.dev"
  },
  "author": {
    "name": "Kartikey Chauhan",
    "email": "kartychauhan@gmail.com",
    "url": "https://carteakey.dev/"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-fetch": "^5.1.1",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@11ty/eleventy-plugin-rss": "^2.0.4",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@11ty/eleventy-plugin-webc": "^0.11.2",
    "@netlify/functions": "^5.1.2",
    "@tailwindcss/cli": "^4.2.1",
    "@upstash/redis": "^1.36.2",
    "axios": "^1.13.5",
    "dotenv": "^17.3.1",
    "eleventy-plugin-toc": "^1.1.5",
    "exif-reader": "^2.0.3",
    "glob": "^13.0.6",
    "inquirer": "^13.3.0",
    "js-yaml": "^4.1.1",
    "luxon": "^3.7.2",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-emoji": "^3.0.0",
    "node-fetch": "^3.3.2",
    "npm-check-updates": "^19.6.0",
    "npm-run-all": "^4.1.5",
    "openai": "^6.25.0",
    "sharp": "^0.34.5",
    "steamwidgets": "^1.0.9",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "eleventy-google-fonts": "^0.1.0",
    "eleventy-plugin-feathericons": "^2.0.0",
    "netlify-plugin-cache": "^1.0.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1"
  }
}
