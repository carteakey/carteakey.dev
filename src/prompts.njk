---
layout: layouts/base.njk
title: Prompt Library
description: A collection of prompts to test and benchmark language models
eleventyNavigation:
  key: Prompts
  order: 11
permalink: /prompts/
---

{% include "components/breadcrumbs.njk" %}

{% set promptsList = collections.prompts | reverse %}
{% set totalCount = promptsList | length %}
{% set categories = promptsList | map('data.category') | uniq | sort %}

{% set pageTitle = title %}
{% set pageDescription = "Test prompts for evaluating local and remote language models across coding, writing, multimodal, and reasoning tasks." %}
{% set itemCount = totalCount %}
{% set itemLabel = "prompts" %}

<div class="max-w-5xl mx-auto">
  {% include "components/page-header.njk" %}

  <div class="mt-2 flex flex-wrap items-center gap-3 text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400">
    <div class="flex flex-wrap gap-1">
      {% for category in categories %}
        <a href="#{{ category | slugify }}" class="tag tag-interactive text-[0.65rem]">{{ category }}</a>
      {% endfor %}
    </div>
  </div>

  {% for category in categories %}
    {% set items = promptsList | selectattr('data.category', 'equalto', category) %}
    {% set catCount = items | length %}
    <section id="{{ category | slugify }}" class="mt-8">
      <h2 class="text-sm font-semibold text-gray-900 dark:text-white flex items-center gap-2">
        {{ category }}
        <span class="text-xs font-normal text-gray-500">{{ catCount }}</span>
      </h2>

      <div class="mt-3 space-y-2">
        {% for prompt in items %}
          <article class="card card-hover card-compact group">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <a href="{{ prompt.url }}" class="text-sm font-semibold text-gray-900 link-accent dark:text-white">
                  {{ prompt.data.title }}
                </a>
                {% if prompt.data.description %}
                  <p class="mt-1 text-xs text-gray-600 dark:text-gray-400 line-clamp-2">{{ prompt.data.description }}</p>
                {% endif %}
                {% if prompt.data.tags %}
                  <div class="mt-2 flex flex-wrap gap-1">
                    {% for tag in prompt.data.tags %}
                      <span class="text-[0.6rem] px-1.5 py-0.5 rounded bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400">{{ tag }}</span>
                    {% endfor %}
                  </div>
                {% endif %}
              </div>
              <time class="text-[0.65rem] text-gray-400 dark:text-gray-500 shrink-0 mt-0.5">
                {{ prompt.date | readableDate }}
              </time>
            </div>
          </article>
        {% endfor %}
      </div>
    </section>
  {% endfor %}

  <div class="mt-10 card card-compact">
    <p class="text-sm text-gray-600 dark:text-gray-300">
      Have a useful prompt to add? <a href="mailto:{{ metadata.author.email }}" class="font-semibold accent-link">Send it my way</a>.
    </p>
  </div>
</div>

<style>
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>
