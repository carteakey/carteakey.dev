---
layout: layouts/base.njk
title: Reading
description: Books I'm reading, have read, and want to read.
permalink: /reading/
eleventyNavigation:
  key: Reading
  order: 8
---

{% include "components/breadcrumbs.njk" %}

<div class="not-prose mb-6">
  <h1 class="text-2xl font-semibold tracking-tight m-0">Reading</h1>
  <p class="text-sm text-gray-400 dark:text-gray-500 mt-1">Books I'm reading, have read, and want to read.</p>
</div>

{% if reading.currently_reading and reading.currently_reading.length > 0 %}
<section class="not-prose mb-8">
  <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-3">Currently Reading</h2>
  <div class="divide-y divide-gray-100 dark:divide-gray-800/80">
    {% for book in reading.currently_reading %}
    <div class="py-3.5">
      <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-4">
        <div class="flex-1 min-w-0">
          <span class="font-semibold text-gray-900 dark:text-gray-100 text-sm">{{ book.title }}</span>
          <span class="text-sm text-gray-400 dark:text-gray-500"> - {{ book.author }}</span>
        </div>
        <span class="meta-text text-xs text-gray-400 dark:text-gray-500 shrink-0">{{ book.progress }}%</span>
      </div>
      {# Progress bar #}
      <div class="mt-2 h-1 bg-gray-100 dark:bg-gray-800 rounded-full overflow-hidden w-full max-w-sm">
        <div class="h-full rounded-full" style="width: {{ book.progress }}%; background: var(--accent-color); transition: width 0.3s;"></div>
      </div>
      {% if book.notes %}
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1.5 mb-0">{{ book.notes }}</p>
      {% endif %}
    </div>
    {% endfor %}
  </div>
</section>
{% endif %}

{% if reading.read and reading.read.length > 0 %}
<section class="not-prose mb-8">
  <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-3">Read</h2>
  <div class="divide-y divide-gray-100 dark:divide-gray-800/80">
    {% for book in reading.read %}
    <article class="py-3.5">
      <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-4">
        <div class="flex-1 min-w-0">
          <span class="font-semibold text-gray-900 dark:text-gray-100 text-sm">{{ book.title }}</span>
          <span class="text-sm text-gray-400 dark:text-gray-500"> - {{ book.author }}</span>
        </div>
        <div class="flex items-center gap-2 shrink-0 mt-0.5 sm:mt-0">
          {% if book.finished %}
            <time class="meta-text text-xs text-gray-400 dark:text-gray-500">{{ book.finished | readableDate }}</time>
          {% endif %}
          {% if book.rating %}
            <span class="meta-text text-xs" style="color: var(--accent-color);">{{ "★" * book.rating }}{{ "☆" * (5 - book.rating) }}</span>
          {% endif %}
        </div>
      </div>
      {% if book.notes %}
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1 mb-0">{{ book.notes }}</p>
      {% endif %}
    </article>
    {% endfor %}
  </div>
</section>
{% endif %}

{% if reading.want_to_read and reading.want_to_read.length > 0 %}
<section class="not-prose mb-4">
  <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-3">Want to Read</h2>
  <ul class="divide-y divide-gray-100 dark:divide-gray-800/80 list-none m-0 p-0">
    {% for book in reading.want_to_read %}
    <li class="py-2.5 flex items-baseline gap-2">
      <span class="w-1.5 h-1.5 rounded-full bg-gray-300 dark:bg-gray-600 shrink-0 mt-1.5"></span>
      <div>
        <span class="text-sm text-gray-800 dark:text-gray-200 font-medium">{{ book.title }}</span>
        <span class="text-sm text-gray-400 dark:text-gray-500"> - {{ book.author }}</span>
      </div>
    </li>
    {% endfor %}
  </ul>
</section>
{% endif %}
