{# <hr />
<h2>Personal</h2>
<p>
  
</p> #}

<div class="mx-auto">
  <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">Here are some of my personal projects.</p>

  <ul class="not-prose divide-y divide-gray-200 dark:divide-gray-700">
    {% for project in projects.projects %}
      <li class="group flex items-start gap-4 py-4">
        <div class="flex-1 min-w-0">
          <div class="flex flex-wrap items-center gap-2">
            <a href="{% if project.url %}{{ project.url }}{% else %}{{ project.github }}{% endif %}" title="View Project" class="inline-flex items-center gap-1 font-semibold text-gray-900 link-accent dark:text-gray-100">
              {{ project.title }}
              {% feather "arrow-up-right", class="w-3.5 h-3.5 opacity-40 group-hover:opacity-100 transition-opacity" %}
            </a>
            {% for tag in project.tags %}
              <span class="badge badge-tag badge-compact">#{{ tag }}</span>
            {% endfor %}
          </div>
          <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
            {{ project.description }}
          </p>
        </div>
        {% if project.github %}
          <a class="mt-1 shrink-0 text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300 transition-colors" title="View Code" href="{{ project.github }}">
            {% feather "github", class="w-4 h-4" %}
          </a>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
<hr />
<h2>GitHub Profile</h2>
<div class="not-prose">
  <a href="https://github.com/carteakey" target="_blank" rel="noopener" class="block" style="text-decoration:none;">
    <div class="surface surface-hover surface-padding cursor-pointer">

      {# Avatar + name #}
      <div class="flex items-center gap-3 mb-4">
        <img src="{{ githubCard.avatarUrl }}" alt="{{ githubCard.login }} avatar" width="40" height="40" class="rounded-full border border-gray-200 dark:border-gray-700">
        <div>
          <p class="font-semibold text-sm text-gray-900 dark:text-gray-100 m-0">{{ githubCard.name }}</p>
          <p class="text-xs text-gray-500 dark:text-gray-400 m-0 meta-text">@{{ githubCard.login }}</p>
        </div>
        <span class="ml-auto">{% feather "github", class="w-4 h-4 text-gray-400 dark:text-gray-500" %}</span>
      </div>

      {% if githubCard.bio %}
        <p class="text-xs text-gray-600 dark:text-gray-400 mb-4 m-0">{{ githubCard.bio }}</p>
      {% endif %}

      {# Stats row #}
      <div class="grid grid-cols-4 gap-3 mb-4">
        <div class="text-center">
          <p class="text-lg font-bold text-gray-900 dark:text-gray-100 m-0">{{ githubCard.totalStars }}</p>
          <p class="text-[0.65rem] text-gray-500 dark:text-gray-400 uppercase tracking-wide m-0 meta-text">Stars</p>
        </div>
        <div class="text-center">
          <p class="text-lg font-bold text-gray-900 dark:text-gray-100 m-0">{{ githubCard.totalForks }}</p>
          <p class="text-[0.65rem] text-gray-500 dark:text-gray-400 uppercase tracking-wide m-0 meta-text">Forks</p>
        </div>
        <div class="text-center">
          <p class="text-lg font-bold text-gray-900 dark:text-gray-100 m-0">{{ githubCard.repoCount }}</p>
          <p class="text-[0.65rem] text-gray-500 dark:text-gray-400 uppercase tracking-wide m-0 meta-text">Repos</p>
        </div>
        <div class="text-center">
          <p class="text-lg font-bold text-gray-900 dark:text-gray-100 m-0">{{ githubCard.followers }}</p>
          <p class="text-[0.65rem] text-gray-500 dark:text-gray-400 uppercase tracking-wide m-0 meta-text">Followers</p>
        </div>
      </div>

      {# Top languages #}
      {% if githubCard.topLanguages | length %}
        <div>
          <p class="text-[0.65rem] text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1.5 m-0 meta-text">Top Languages</p>
          <div class="flex flex-wrap gap-1.5">
            {% for lang in githubCard.topLanguages %}
              <span class="badge badge-tag badge-compact">{{ lang.name }}</span>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    </div>
  </a>
</div>

<hr />
<h2>GitHub Activity</h2>
<div class="not-prose">
  <p class="text-gray-600 dark:text-gray-400 mb-4">
    My contribution activity on GitHub over the past year.
  </p>
  <div class="surface surface-padding not-prose">
    {% include "components/github-contributions.njk" %}
    <p class="text-xs text-gray-500 dark:text-gray-400 mt-2 text-center">
      Data sourced live from <a href="https://github.com/carteakey" class="hover:underline accent-link">GitHub activity</a>.
    </p>
  </div>
</div>

<hr />
<h2>Projects on GitHub</h2>
<p>
  Here are the rest of my projects on <a href="https://github.com/carteakey?tab=repositories">GitHub</a>.
</p>
<div class="not-prose border border-gray-200 dark:border-gray-800 rounded-lg overflow-hidden">
<table class="w-full text-xs">
  <thead>
    <tr class="bg-gray-50 dark:bg-gray-900">
      <th class="text-left px-3 py-2 font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Updated</th>
      <th class="text-left px-3 py-2 font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Name</th>
      <th class="text-left px-3 py-2 font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide hidden sm:table-cell">Description</th>
    </tr>
  </thead>
  <tbody class="divide-y divide-gray-200 dark:divide-gray-800">
    {% for repo in github.repos %}
    <tr class="hover:bg-gray-50 dark:hover:bg-gray-900/50 transition-colors">
      <td class="px-3 py-2 meta-text text-gray-500 dark:text-gray-400 whitespace-nowrap">
        <time>{{ repo.repo_updated | formatDate }}</time>
      </td>
      <td class="px-3 py-2">
        <a href="{{ repo.repo_url }}" class="title-hover font-medium" target="_blank" rel="noopener">
          {{ repo.repo_name }}
        </a>
      </td>
      <td class="px-3 py-2 text-gray-500 dark:text-gray-400 hidden sm:table-cell">
        {{ repo.repo_description }}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
</div>
</div>
