---
templateClass: tmpl-post
layout: layouts/home.njk
title: Projects
redirect_from: /portfolio
eleventyNavigation:
  key: Projects
  order: 4
---

{% set pageEyebrow = "Things I Build" %}
{% set pageTitle = "Projects" %}
{% set pageDescription = "A running list of personal projects, experiments, and the code that powers them." %}
{% set itemCount = projects.projects | length %}
{% set itemLabel = "projects" %}
{% set pageActions = [{ href: "https://github.com/carteakey?tab=repositories", label: "Browse GitHub", external: true, accent: true }] %}

{% include "components/page-header.njk" %}
