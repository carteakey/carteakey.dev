---
layout: layouts/base.njk
title: Feed
description: A unified timeline of posts, snippets, notes, photos, vibes, and /now updates
eleventyNavigation:
  key: Feed
  order: 10
permalink: /feed/
---

{% from "components/feed-card.njk" import feedCard %}
{% include "components/breadcrumbs.njk" %}

<div class="not-prose" x-data="feedPage()">

  <div class="flex items-baseline justify-between mb-3 gap-3 flex-wrap">
    <div class="flex items-baseline gap-3">
      <h1 class="text-2xl font-semibold tracking-tight m-0">Feed</h1>
      <span class="meta-text text-xs text-gray-400 dark:text-gray-500">{{ collections.feed.length }} items</span>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <div class="relative">
        {% feather "search", class="w-3.5 h-3.5 text-gray-400 absolute left-2.5 top-1/2 -translate-y-1/2 pointer-events-none" %}
        <input
          type="text"
          x-model="query"
          placeholder="Search..."
          class="rounded-md border border-gray-200 dark:border-gray-700 bg-transparent py-1.5 pl-8 pr-3 text-sm accent-field focus:outline-none dark:text-gray-100 w-40 placeholder:text-gray-400"
        >
      </div>
      <div class="view-toggle">
        <button type="button" @click="view = 'list'" :class="{ 'active': view === 'list' }" title="List view">
          {% feather "list", class="w-4 h-4" %}
        </button>
        <button type="button" @click="view = 'grid'" :class="{ 'active': view === 'grid' }" title="Grid view">
          {% feather "grid", class="w-4 h-4" %}
        </button>
      </div>
    </div>
  </div>

  {# Type filter chips #}
  <div class="flex flex-wrap gap-1.5 mb-5 text-xs">
    <button @click="typeFilter = ''"
      :class="typeFilter === '' ? 'font-semibold' : 'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'"
      class="px-2 py-0.5 rounded-full border border-gray-200 dark:border-gray-700 transition-colors"
      :style="typeFilter === '' ? 'border-color: var(--accent-color); color: var(--accent-color)' : ''">
      All ({{ collections.feed.length }})
    </button>
    <button @click="typeFilter = 'post'"
      :class="typeFilter === 'post' ? 'font-semibold' : 'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'"
      class="px-2 py-0.5 rounded-full border border-gray-200 dark:border-gray-700 transition-colors"
      :style="typeFilter === 'post' ? 'border-color: var(--accent-color); color: var(--accent-color)' : ''">
      Posts
    </button>
    <button @click="typeFilter = 'snippet'"
      :class="typeFilter === 'snippet' ? 'font-semibold' : 'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'"
      class="px-2 py-0.5 rounded-full border border-gray-200 dark:border-gray-700 transition-colors"
      :style="typeFilter === 'snippet' ? 'border-color: var(--accent-color); color: var(--accent-color)' : ''">
      Snippets
    </button>
    <button @click="typeFilter = 'note'"
      :class="typeFilter === 'note' ? 'font-semibold' : 'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'"
      class="px-2 py-0.5 rounded-full border border-gray-200 dark:border-gray-700 transition-colors"
      :style="typeFilter === 'note' ? 'border-color: var(--accent-color); color: var(--accent-color)' : ''">
      Notes
    </button>
    <button @click="typeFilter = 'photo'"
      :class="typeFilter === 'photo' ? 'font-semibold' : 'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'"
      class="px-2 py-0.5 rounded-full border border-gray-200 dark:border-gray-700 transition-colors"
      :style="typeFilter === 'photo' ? 'border-color: var(--accent-color); color: var(--accent-color)' : ''">
      Photos
    </button>
  </div>

  {# ── LIST VIEW ── #}
  <ul class="feed-list" x-show="view === 'list'" x-cloak>
    {% for item in collections.feed %}
      {{ feedCard(item, {
        variant: 'list',
        outerAttrs: 'data-type="' ~ item.type ~ '" data-title="' ~ (item.title | lower | replace('"', '')) ~ '"'
      }) }}
    {% endfor %}
  </ul>
  <p x-show="view === 'list' && filteredCount === 0" x-cloak class="text-sm text-gray-400 py-8 text-center">No results.</p>

  {# ── GRID VIEW ── #}
  <div x-show="view === 'grid'" x-cloak
    class="grid gap-3 md:grid-cols-2 lg:grid-cols-3 items-start"
    data-feed-masonry
    data-feed-initial="24"
    data-feed-batch="12"
    style="--feed-row-height: 16px;"
  >
    {% for item in collections.feed %}
      {{ feedCard(item, {
        outerAttrs: 'data-type="' ~ item.type ~ '" data-title="' ~ (item.title | lower | replace('"', '')) ~ '"'
      }) }}
    {% endfor %}
  </div>
  <p x-show="view === 'grid' && filteredCount === 0" x-cloak class="text-sm text-gray-400 py-8 text-center">No results.</p>

  <p class="mt-8 text-center text-xs text-gray-400 dark:text-gray-500">
    Updated {{ page.date | readableDate }}
  </p>

</div>

<script>
function feedPage() {
  return {
    view: localStorage.getItem('feed-view') || 'list',
    query: '',
    typeFilter: '',
    filteredCount: 0,
    init() {
      this.$watch('view', v => localStorage.setItem('feed-view', v));
      this.$watch('query', () => this.filterItems());
      this.$watch('typeFilter', () => this.filterItems());
    },
    filterItems() {
      const q = this.query.toLowerCase().trim();
      const t = this.typeFilter;
      const items = document.querySelectorAll('[data-type][data-title]');
      let count = 0;
      items.forEach(el => {
        const title = el.dataset.title || '';
        const type = el.dataset.type || '';
        const matchQ = !q || title.includes(q);
        const matchT = !t || type === t;
        const show = matchQ && matchT;
        el.style.display = show ? '' : 'none';
        if (show) count++;
      });
      this.filteredCount = count;
    }
  }
}
</script>
{% include "components/feed-masonry-script.njk" %}
