---
layout: layouts/base.njk
title: Feed
description: A unified timeline of posts, snippets, microposts, photos, vibes, and /now updates
eleventyNavigation:
  key: Feed
  order: 10
permalink: /feed/
---

{% from "components/feed-card.njk" import feedCard %}
{% include "components/breadcrumbs.njk" %}

<div class="flex items-baseline justify-between mb-2">
  <h1 class="text-2xl font-semibold tracking-tight m-0">Feed</h1>
  <span class="meta-text text-xs text-gray-400 dark:text-gray-500">{{ collections.feed.length }} items</span>
</div>
<p class="text-sm text-gray-500 dark:text-gray-400 mb-6 mt-1">
  Everything in one place — articles, snippets, notes, photos, vibes, and /now snapshots.
</p>

{% set initialVisible = 24 %}
{% set batchSize = 12 %}

<div
  class="grid gap-3 md:grid-cols-2 lg:grid-cols-3 items-start feed-masonry"
  data-feed-masonry
  data-feed-initial="{{ initialVisible }}"
  data-feed-batch="{{ batchSize }}"
  style="--feed-row-height: 16px;"
>
  {% for item in collections.feed %}
    {% set isHidden = loop.index0 >= initialVisible %}
    {% set extraClasses = 'hidden' if isHidden else '' %}
    {% set attrs = 'data-feed-index="' ~ loop.index0 ~ '" data-feed-item' %}
    {{ feedCard(item, {
      extraClasses: extraClasses,
      outerAttrs: attrs
    }) }}
  {% endfor %}
</div>

<p class="mt-8 text-center text-xs text-gray-400 dark:text-gray-500">
  Updated {{ page.date | readableDate }}
</p>

{% if collections.feed.length > initialVisible %}
  <div class="mt-6 flex justify-center">
    <button
      type="button"
      class="accent-button-outline accent-focus inline-flex items-center gap-2 rounded-full px-5 py-2 text-sm font-medium"
      data-feed-load-more
    >
      Load more
      {% feather "refresh-cw", class="h-4 w-4" %}
    </button>
  </div>
{% endif %}
{% include "components/feed-masonry-script.njk" %}
