---
layout: layouts/base.njk
title: Feed
description: A unified timeline of posts, snippets, microposts, photos, vibes, and /now updates
eleventyNavigation:
  key: Feed
  order: 10
permalink: /feed/
---

{% from "components/feed-card.njk" import feedCard %}
{% include "components/breadcrumbs.njk" %}

<div class="not-prose" x-data="feedPage()">

  <div class="flex items-center justify-between mb-3 gap-3 flex-wrap">
    <div>
      <h1 class="text-xl font-semibold tracking-tight m-0">Feed</h1>
      <p class="text-xs text-gray-400 dark:text-gray-500 m-0 mt-0.5">
        Everything in one place — posts, snippets, notes, photos, vibes, /now snapshots.
      </p>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      {# View toggle #}
      <div class="flex border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden text-xs">
        <button @click="view = 'list'"
          :class="view === 'list' ? 'bg-gray-100 dark:bg-gray-800 font-medium' : 'hover:bg-gray-50 dark:hover:bg-gray-800'"
          class="px-2.5 py-1.5 flex items-center gap-1 transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
          List
        </button>
        <button @click="view = 'grid'"
          :class="view === 'grid' ? 'bg-gray-100 dark:bg-gray-800 font-medium' : 'hover:bg-gray-50 dark:hover:bg-gray-800'"
          class="px-2.5 py-1.5 flex items-center gap-1 transition-colors border-l border-gray-200 dark:border-gray-700">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
          Grid
        </button>
      </div>
    </div>
  </div>

  {# Search #}
  <div class="mb-4">
    <input
      type="search"
      x-model="query"
      placeholder="Search feed…"
      class="w-full sm:max-w-xs text-xs px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-700 dark:text-gray-300 focus:outline-none focus:ring-1 focus:ring-amber-400 dark:focus:ring-amber-500 placeholder-gray-400"
    />
  </div>

  {# Type filter chips #}
  <div class="flex flex-wrap gap-1.5 mb-5 text-xs">
    <button @click="typeFilter = ''"
      :class="typeFilter === '' ? 'font-semibold' : 'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'"
      class="px-2 py-0.5 rounded-full border border-gray-200 dark:border-gray-700 transition-colors"
      :style="typeFilter === '' ? 'border-color: var(--accent-color); color: var(--accent-color)' : ''">
      All ({{ collections.feed.length }})
    </button>
    <button @click="typeFilter = 'post'"
      :class="typeFilter === 'post' ? 'font-semibold' : 'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'"
      class="px-2 py-0.5 rounded-full border border-gray-200 dark:border-gray-700 transition-colors"
      :style="typeFilter === 'post' ? 'border-color: var(--accent-color); color: var(--accent-color)' : ''">
      Posts
    </button>
    <button @click="typeFilter = 'snippet'"
      :class="typeFilter === 'snippet' ? 'font-semibold' : 'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'"
      class="px-2 py-0.5 rounded-full border border-gray-200 dark:border-gray-700 transition-colors"
      :style="typeFilter === 'snippet' ? 'border-color: var(--accent-color); color: var(--accent-color)' : ''">
      Snippets
    </button>
    <button @click="typeFilter = 'micropost'"
      :class="typeFilter === 'micropost' ? 'font-semibold' : 'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'"
      class="px-2 py-0.5 rounded-full border border-gray-200 dark:border-gray-700 transition-colors"
      :style="typeFilter === 'micropost' ? 'border-color: var(--accent-color); color: var(--accent-color)' : ''">
      Notes
    </button>
    <button @click="typeFilter = 'photo'"
      :class="typeFilter === 'photo' ? 'font-semibold' : 'text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300'"
      class="px-2 py-0.5 rounded-full border border-gray-200 dark:border-gray-700 transition-colors"
      :style="typeFilter === 'photo' ? 'border-color: var(--accent-color); color: var(--accent-color)' : ''">
      Photos
    </button>
  </div>

  {# ── LIST VIEW ── #}
  <ul class="feed-list" x-show="view === 'list'" x-cloak>
    {% for item in collections.feed %}
      {{ feedCard(item, {
        variant: 'list',
        outerAttrs: 'data-type="' ~ item.type ~ '" data-title="' ~ (item.title | lower | replace('"', '')) ~ '"'
      }) }}
    {% endfor %}
  </ul>
  <p x-show="view === 'list' && filteredCount === 0" x-cloak class="text-sm text-gray-400 py-8 text-center">No results.</p>

  {# ── GRID VIEW ── #}
  <div x-show="view === 'grid'" x-cloak
    class="grid gap-3 md:grid-cols-2 lg:grid-cols-3 items-start"
    data-feed-masonry
    data-feed-initial="24"
    data-feed-batch="12"
    style="--feed-row-height: 16px;"
  >
    {% for item in collections.feed %}
      {{ feedCard(item, {
        outerAttrs: 'data-type="' ~ item.type ~ '" data-title="' ~ (item.title | lower | replace('"', '')) ~ '"'
      }) }}
    {% endfor %}
  </div>
  <p x-show="view === 'grid' && filteredCount === 0" x-cloak class="text-sm text-gray-400 py-8 text-center">No results.</p>

  <p class="mt-8 text-center text-xs text-gray-400 dark:text-gray-500">
    Updated {{ page.date | readableDate }}
  </p>

</div>

<script>
function feedPage() {
  return {
    view: localStorage.getItem('feed-view') || 'list',
    query: '',
    typeFilter: '',
    filteredCount: 0,
    init() {
      this.$watch('view', v => localStorage.setItem('feed-view', v));
      this.$watch('query', () => this.filterItems());
      this.$watch('typeFilter', () => this.filterItems());
    },
    filterItems() {
      const q = this.query.toLowerCase().trim();
      const t = this.typeFilter;
      const items = document.querySelectorAll('[data-type][data-title]');
      let count = 0;
      items.forEach(el => {
        const title = el.dataset.title || '';
        const type = el.dataset.type || '';
        const matchQ = !q || title.includes(q);
        const matchT = !t || type === t;
        const show = matchQ && matchT;
        el.style.display = show ? '' : 'none';
        if (show) count++;
      });
      this.filteredCount = count;
    }
  }
}
</script>
{% include "components/feed-masonry-script.njk" %}
