---
pagination:
  data: collections.snippetTags
  size: 1
  alias: tag
  addAllPagesToCollections: true
layout: layouts/base.njk
eleventyComputed:
  title: 'Snippets tagged "{{ tag }}"'
permalink: /snippets/tags/{{ tag | slugify }}/
---

{% include "components/breadcrumbs.njk" %}

{% set pageEyebrow = "Tag Archive" %}
{% set pageTitle = 'Snippets tagged "' ~ tag ~ '"' %}
{% set pageDescription = "Every snippet filed under this topic." %}

{% include "components/page-header.njk" %}

<div class="not-prose divide-y divide-gray-200 dark:divide-gray-800">
  {%- for snippet in collections.snippets | reverse -%}
    {% if tag in snippet.data.tags %}
      <article class="py-3 flex flex-col gap-1">
        <a href="{{ snippet.url }}" class="font-medium text-gray-900 dark:text-gray-100 accent-link" style="text-decoration:none;">{{ snippet.data.title }}</a>
        <div class="flex items-center gap-3">
          <time class="meta-text text-[0.68rem] text-gray-400 dark:text-gray-500" datetime="{{ snippet.date | htmlDateString }}">{{ snippet.date | readableDate }}</time>
          {% if snippet.data.language %}<span class="badge badge-tag badge-compact">{{ snippet.data.language }}</span>{% endif %}
          {% for snippetTag in snippet.data.tags | filterTagList %}
            {% if snippetTag != "snippets" %}
              <a href="/snippets/tags/{{ snippetTag | slugify }}/" class="badge badge-tag badge-compact badge-interactive">#{{ snippetTag }}</a>
            {% endif %}
          {% endfor %}
        </div>
      </article>
    {% endif %}
  {%- endfor -%}
</div>

<p class="mt-6 text-sm"><a href="/snippets/" class="accent-link">← Back to all snippets</a></p>
