{% from "components/authorship-badge.njk" import authorshipBadge %}
<ul reversed class="postlist w-full list-none m-0 p-0 divide-y divide-gray-100 dark:divide-gray-800/80"
  style="counter-reset: start-from {{ (postslistCounter or postslist.length) + 1 }}">
  {% for post in postslist | reverse %}
  <li class="postlist-item{% if post.url == url %} postlist-item-active{% endif %}">
    <article class="py-3.5 group">
      <div class="flex flex-col md:flex-row md:gap-6">

        {# Left: date + tags (desktop) #}
        <div class="shrink-0 md:w-36 flex flex-col gap-1 pt-0.5">
          <time class="meta-text text-xs text-gray-400 dark:text-gray-500" datetime="{{ post.date | postDate }}">{{ post.date | postDate }}</time>
          <div class="hidden md:flex flex-wrap gap-1 mt-0.5">
            {% for tag in post.data.tags | filterTagList %}
            {% set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
            <a href="{{ tagUrl | url }}" class="badge badge-tag badge-compact badge-interactive" style="text-decoration: none;">#{{ tag }}</a>
            {% endfor %}
          </div>
        </div>

        {# Right: title + description #}
        <div class="flex-1 min-w-0">
          <div class="leading-snug">
            {% if post.data.pinned %}
              <span class="inline-flex items-center mr-1.5 align-middle" style="color: var(--accent-color);" title="Pinned" aria-label="Pinned">{% feather "bookmark", class="w-3.5 h-3.5 fill-current opacity-20" %}</span>
            {% endif %}
            {{ authorshipBadge(post.data.authored_by, compact=true) }}
            <a href="{{ post.url | url }}" class="font-semibold text-gray-900 dark:text-gray-100 title-hover" style="text-decoration: none;">
              {% if post.data.title %}{{ post.data.title }}{% else %}<code>{{ post.url }}</code>{% endif %}
            </a>
          </div>

          {% if post.data.description %}
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5 m-0 leading-relaxed">{{ post.data.description }}</p>
          {% endif %}

          {# Mobile: date + tags #}
          <div class="md:hidden flex flex-wrap items-center gap-x-2 gap-y-1 mt-1.5">
            <span class="meta-text text-[0.65rem] text-gray-400 dark:text-gray-500">{{ post.date | postDate }}</span>
            {% for tag in post.data.tags | filterTagList %}
            {% set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
            <a href="{{ tagUrl | url }}" class="badge badge-tag badge-compact badge-interactive" style="text-decoration: none;">#{{ tag }}</a>
            {% endfor %}
          </div>
        </div>

      </div>
    </article>
  </li>
  {% endfor %}
</ul>
