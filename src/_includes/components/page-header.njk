{#
  Shared page header for collection, profile, and utility pages.
#}

{% set pageBadges = pageBadges or [] %}
{% set pageActions = pageActions or [] %}

<header class="page-header not-prose">
  <div class="page-header-main">
    {% if pageEyebrow %}
      <p class="page-eyebrow">{{ pageEyebrow }}</p>
    {% endif %}

    <div class="page-header-title-row">
      <h1 class="page-header-title">
        {% if pageIcon %}{% feather pageIcon, class="w-5 h-5 opacity-80" %}{% endif %}
        <span>{{ pageTitle }}</span>
      </h1>
      {% if itemCount %}
        <span class="badge-count" aria-label="{{ itemCount }} {{ itemLabel or 'items' }}">{{ itemCount }}</span>
      {% endif %}
    </div>

    {% if pageDescription %}
      <p class="page-header-description">{{ pageDescription | safe }}</p>
    {% endif %}

    {% if pageBadges.length or pageActions.length %}
      <div class="page-header-supporting">
        {% for badge in pageBadges %}
          {% if badge.href %}
            <a href="{{ badge.href }}" class="badge badge-tag badge-interactive no-underline">{{ badge.label }}</a>
          {% else %}
            <span class="badge badge-tag">{{ badge.label }}</span>
          {% endif %}
        {% endfor %}

        {% for action in pageActions %}
          <a href="{{ action.href }}" class="page-header-link{% if action.accent %} accent-link{% endif %}" {% if action.external %}target="_blank" rel="noopener"{% endif %}>{{ action.label }}</a>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  {% if pageMeta %}
    <div class="page-header-aside">
      {% if pageMetaLabel %}
        <span class="page-header-meta-label">{{ pageMetaLabel }}</span>
      {% endif %}
      <span class="page-header-meta-value">{{ pageMeta | safe }}</span>
    </div>
  {% endif %}
</header>
