{% if strava and strava.length > 0 %}
  {% set workouts = strava | head(3) %}
  <div class="strava-snippet space-y-3">
    <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 m-0">Recent Workouts</h3>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {% for activity in workouts %}
        <article class="feed-card-full flex flex-col overflow-hidden p-0">
          {% if activity.mapImageUrl %}
            <a href="{{ activity.url }}" target="_blank" rel="noopener noreferrer" class="block">
              <img src="{{ activity.mapImageUrl }}" alt="Map of {{ activity.name }}" loading="lazy" decoding="async" class="h-36 w-full object-cover">
            </a>
          {% endif %}

          <div class="flex flex-col gap-3 p-3">
            <div class="flex flex-col gap-1">
              <a href="{{ activity.url }}" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-gray-900 dark:text-gray-100 transition-colors" style="text-decoration:none;" onmouseover="this.style.color='var(--accent-color)'" onmouseout="this.style.color=''">
                {{ activity.name }}
              </a>
              <div class="flex flex-wrap items-center gap-1.5">
                <span class="badge badge-tag badge-compact">{{ activity.type }}</span>
                <time class="meta-text text-[0.65rem] text-gray-400 dark:text-gray-500">{{ activity.start_date | readableDate }}</time>
              </div>
            </div>

            <dl class="grid grid-cols-2 gap-2">
              <div class="flex flex-col gap-0.5">
                <span class="meta-text text-[0.6rem] uppercase text-gray-400 dark:text-gray-500">Distance</span>
                <span class="text-xs font-semibold text-gray-800 dark:text-gray-200">{{ activity.distance }} mi</span>
              </div>
              <div class="flex flex-col gap-0.5">
                <span class="meta-text text-[0.6rem] uppercase text-gray-400 dark:text-gray-500">Time</span>
                <span class="text-xs font-semibold text-gray-800 dark:text-gray-200">{{ activity.moving_time }} min</span>
              </div>
              {% if activity.total_elevation_gain %}
                <div class="flex flex-col gap-0.5">
                  <span class="meta-text text-[0.6rem] uppercase text-gray-400 dark:text-gray-500">Elevation</span>
                  <span class="text-xs font-semibold text-gray-800 dark:text-gray-200">{{ activity.total_elevation_gain }} ft</span>
                </div>
              {% endif %}
            </dl>
          </div>
        </article>
      {% endfor %}
    </div>
    <p class="text-sm m-0"><a href="/workouts" class="accent-link">View all workouts →</a></p>
  </div>
{% endif %}
