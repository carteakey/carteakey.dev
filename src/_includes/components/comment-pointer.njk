{% macro commentPointer(options) %}
  {% set opts = options or {} %}
  {% set variant = opts.variant or 'inline' %}
  {% set title = opts.title or 'Join the conversation' %}
  {% set description = opts.description or 'Have thoughts, questions, or counterpoints? Drop them in the thread below.' %}
  {% set cta = opts.cta or 'Jump to comments' %}
  
  {% if variant == 'sidebar' %}
    {% set baseClasses = 'comment-pointer surface surface-padding space-y-3' %}
  {% else %}
    {% set baseClasses = 'comment-pointer surface surface-padding space-y-4 my-10' %}
  {% endif %}
  
  <section class="{{ baseClasses }}">
    <div class="flex items-center gap-2">
      {% feather "message-circle", class="w-4 h-4 opacity-60" %}
      <p class="post-panel-title m-0">{{ title }}</p>
    </div>
    <p class="comment-pointer-copy m-0">{{ description }}</p>
    <a href="#post-comments" class="comment-pointer-cta">
      {% feather "arrow-down", class="w-4 h-4" %}
      {{ cta }}
    </a>
  </section>
{% endmacro %}
