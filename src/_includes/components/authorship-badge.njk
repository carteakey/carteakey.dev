{% macro authorshipBadge(authored_by) %}
  {% if authored_by == 'human' %}
    <span class="inline-flex items-center gap-0.5 text-[0.62rem] font-semibold uppercase tracking-wider rounded px-1 py-0.5 align-middle" style="color: #16a34a; background: color-mix(in srgb, #16a34a 12%, transparent);">{% feather "edit-2", class="w-2.5 h-2.5 inline" %} Human</span>
  {% elif authored_by == 'ai-assisted' %}
    <span class="inline-flex items-center gap-0.5 text-[0.62rem] font-semibold uppercase tracking-wider rounded px-1 py-0.5 align-middle" style="color: #2563eb; background: color-mix(in srgb, #2563eb 12%, transparent);">{% feather "zap", class="w-2.5 h-2.5 inline" %} AI Assisted</span>
  {% elif authored_by == 'ai-generated' %}
    <span class="inline-flex items-center gap-0.5 text-[0.62rem] font-semibold uppercase tracking-wider rounded px-1 py-0.5 align-middle" style="color: #7c3aed; background: color-mix(in srgb, #7c3aed 12%, transparent);">{% feather "cpu", class="w-2.5 h-2.5 inline" %} AI Generated</span>
  {% else %}
    <span class="inline-flex items-center gap-0.5 text-[0.62rem] font-semibold uppercase tracking-wider rounded px-1 py-0.5 align-middle" style="color: #6b7280; background: color-mix(in srgb, #6b7280 12%, transparent);">{% feather "help-circle", class="w-2.5 h-2.5 inline" %} Unclassified</span>
  {% endif %}
{% endmacro %}
