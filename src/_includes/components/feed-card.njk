{% from "components/authorship-badge.njk" import authorshipBadge %}
{% macro feedCard(item, options) %}
  {% set opts = options or {} %}
  {% set variant = opts.variant or 'full' %}
  {% set showSummary = true %}
  {% set extraClasses = (opts.extraClasses or '') | trim %}
  {% set outerAttrs = (opts.outerAttrs or '') | trim %}
  {% if opts.showSummary is defined %}
    {% set showSummary = opts.showSummary %}
  {% endif %}

  {% set showTags = true %}
  {% if opts.showTags is defined %}
    {% set showTags = opts.showTags %}
  {% endif %}

  {% set itemImage = item.image %}
  {% set itemImageAlt = item.imageAlt or item.title or '' %}

  {% set isNote = item.type == 'note' %}
  {% set isSnippet = item.type == 'snippet' %}
  {% set isPhoto = item.type == 'photo' %}
  {% set isVibe = item.type == 'vibe' %}
  {% set isNow = item.type == 'now' %}
  {% set isTil = item.type == 'til' %}
  {% set isFolio = item.type == 'folio' %}
  {% set isQuotation = item.type == 'quotation' %}

  {# Type color dot classes #}
  {% set dotColor = "bg-gray-400" %}
  {% set badgeLabel = "Update" %}
  {% set typeBadgeClass = "badge-type-default" %}
  {% if item.type == 'post' %}
    {% set dotColor = "bg-blue-400" %}
    {% set badgeLabel = "Post" %}
    {% set typeBadgeClass = "badge-type-post" %}
  {% elif isSnippet %}
    {% set dotColor = "bg-purple-400" %}
    {% set badgeLabel = "Snippet" %}
    {% set typeBadgeClass = "badge-type-snippet" %}
  {% elif isNote %}
    {% set dotColor = "bg-amber-400" %}
    {% set badgeLabel = "Note" %}
    {% set typeBadgeClass = "badge-type-note" %}
  {% elif isPhoto %}
    {% set dotColor = "bg-emerald-400" %}
    {% set badgeLabel = "Photo" %}
    {% set typeBadgeClass = "badge-type-photo" %}
  {% elif isVibe %}
    {% set dotColor = "bg-pink-400" %}
    {% set badgeLabel = "Vibe" %}
    {% set typeBadgeClass = "badge-type-vibe" %}
  {% elif isNow %}
    {% set dotColor = "bg-cyan-400" %}
    {% set badgeLabel = "Now" %}
    {% set typeBadgeClass = "badge-type-now" %}
  {% elif isTil %}
    {% set dotColor = "bg-yellow-400" %}
    {% set badgeLabel = "TIL" %}
    {% set typeBadgeClass = "badge-type-til" %}
  {% elif isFolio %}
    {% set dotColor = "bg-orange-400" %}
    {% set badgeLabel = "Folio" %}
    {% set typeBadgeClass = "badge-type-folio" %}
  {% elif isQuotation %}
    {% set dotColor = "bg-stone-500" %}
    {% set badgeLabel = "Quotation" %}
    {% set typeBadgeClass = "badge-type-quotation" %}
  {% endif %}

  {# ── STREAM VARIANT (lifestream style) ── #}
  {% if variant == 'stream' %}
  <article class="feed-card-stream{% if extraClasses %} {{ extraClasses }}{% endif %} group py-1.5" {% if outerAttrs %}{{ outerAttrs | safe }}{% endif %}>
    <div class="flex flex-col md:flex-row md:gap-8">
      {# Left column: Date & Type #}
      <div class="shrink-0 md:w-28 pt-1 flex flex-row md:flex-col gap-3 md:gap-1.5 items-center md:items-start mb-3 md:mb-0">
        <time class="meta-text text-sm md:text-xs text-gray-500 dark:text-gray-400" datetime="{{ item.date | htmlDateString }}">{{ item.date | readableDate }}</time>
        
        <div class="flex items-center gap-1.5 md:mt-0.5">
          <span class="badge badge-type badge-compact {{ typeBadgeClass }}">{{ badgeLabel }}</span>
        </div>
        
        <a href="{{ item.url | url }}" class="hidden md:inline-block mt-2 text-xs text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" style="text-decoration: none;">Permalink →</a>
      </div>

      {# Right column: Content #}
      <div class="flex-1 min-w-0 border-b border-gray-100 dark:border-gray-800/80 pb-6 group-last:border-0 group-last:pb-0">
        {# Title (for posts, tils, snippets, notes) #}
        {% if not (isQuotation or isVibe or isPhoto or isNow) %}
          <div class="leading-snug mb-1.5 flex items-center flex-wrap gap-2">
            {% if item.pinned %}
              <span class="badge badge-accent badge-compact flex items-center gap-1" title="Pinned" aria-label="Pinned">{% feather "bookmark", class="w-3 h-3" %} Pinned</span>
            {% endif %}
            {% if item.featured %}
              <span class="badge badge-featured badge-compact" title="Featured" aria-label="Featured">★ Featured</span>
            {% endif %}
            {% if item.authored_by is defined %}{{ authorshipBadge(item.authored_by, compact=true) }}{% endif %}
            {% if item.title %}
              {% if item.url %}
                <a href="{{ item.url | url }}" class="font-semibold text-gray-900 dark:text-gray-100 title-hover" style="text-decoration: none;">
                  {{ item.title }}
                </a>
              {% else %}
                <span class="font-semibold text-gray-900 dark:text-gray-100">
                  {{ item.title }}
                </span>
              {% endif %}
            {% endif %}
          </div>
        {% else %}
          {# For quotes/photos/vibes/now, show pinned/author above the content #}
          {% if item.pinned or item.featured or item.authored_by is defined %}
          <div class="flex items-center gap-2 mb-1.5">
            {% if item.pinned %}
              <span class="badge badge-accent badge-compact flex items-center gap-1">{% feather "bookmark", class="w-3 h-3" %} Pinned</span>
            {% endif %}
            {% if item.featured %}
              <span class="badge badge-featured badge-compact">★ Featured</span>
            {% endif %}
            {% if item.authored_by is defined %}{{ authorshipBadge(item.authored_by, compact=true) }}{% endif %}
          </div>
          {% endif %}
        {% endif %}

        {# Body Content #}
        <div class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed site-content prose-sm max-w-none">
          {% if isNote or isNow or isTil %}
            <div x-data="{ expanded: false, isOverflowing: false }"
                 x-init="setTimeout(() => { if ($refs.content) isOverflowing = $refs.content.scrollHeight > 360; }, 50)">
              <div x-ref="content" :class="!expanded && isOverflowing ? 'max-h-[20rem] overflow-hidden relative' : ''">
                {{ item.original.templateContent | safe }}
                <div x-show="!expanded && isOverflowing" class="feed-card-note-fade absolute bottom-0 left-0 right-0 h-24 pointer-events-none"></div>
              </div>
              <div x-show="isOverflowing" class="mt-2" x-cloak>
                <button type="button" @click="expanded = !expanded" class="text-xs font-medium transition-colors font-sans hover:underline focus:outline-none" style="color: var(--accent-color);">
                  <span x-show="!expanded">Read full {% if isNote %}note{% elif isNow %}update{% else %}TIL{% endif %} &darr;</span>
                  <span x-show="expanded">Show less &uarr;</span>
                </button>
              </div>
            </div>
          {% elif isQuotation %}
            <div class="italic text-gray-700 dark:text-gray-300 border-l-2 pl-4 py-0.5 m-0 relative" style="border-color: var(--accent-color);">
              <span class="absolute left-1.5 -top-2.5 text-4xl font-serif text-gray-400 opacity-40 leading-none">"</span>
              <div class="relative z-10">{{ item.original.templateContent | safe }}</div>
            </div>
            <div class="mt-3 flex flex-col gap-3">
              <div class="flex flex-col">
                <span class="font-medium text-gray-900 dark:text-gray-100 text-sm">
                  - {% if item.original.data.authorUrl %}<a href="{{ item.original.data.authorUrl }}" target="_blank" rel="noopener" class="hover:underline">{{ item.original.data.author }}</a>{% else %}{{ item.original.data.author }}{% endif %}
                </span>
                {% if item.original.data.source %}
                  <span class="text-xs text-gray-500 mt-0.5">
                    {% if item.original.data.sourceUrl %}
                      <a href="{{ item.original.data.sourceUrl }}" target="_blank" rel="noopener" class="hover:underline">{{ item.original.data.source }}</a>
                    {% else %}
                      {{ item.original.data.source }}
                    {% endif %}
                  </span>
                {% endif %}
              </div>
            </div>
          {% elif isPhoto or isVibe or item.media %}
            <figure class="m-0 overflow-hidden rounded border border-gray-200 dark:border-gray-700 not-prose">
              <img src="{{ item.media.src }}" alt="{{ item.media.alt }}" loading="lazy" decoding="async" class="w-full h-auto block m-0">
              {% if item.summary %}
                <figcaption class="px-3 py-2 text-xs text-gray-500 dark:text-gray-400 bg-gray-50 dark:bg-gray-800/50 border-t border-gray-200 dark:border-gray-700 m-0">{{ item.summary }}</figcaption>
              {% endif %}
            </figure>
          {% elif item.type == 'post' or isSnippet %}
            <div class="{% if itemImage and item.type == 'post' %}flex items-start gap-3{% endif %}">
              <div class="min-w-0 flex-1">
                {% if item.summary %}
                  <p class="mt-0 mb-1.5 font-medium text-gray-800 dark:text-gray-200">{{ item.summary }}</p>
                {% endif %}
                {% if item.original.templateContent %}
                  {% set previewText = item.original.templateContent | striptags | truncate(300) %}
                  {% if previewText and previewText != item.summary %}
                    <p class="mt-0 text-sm leading-relaxed text-gray-500 dark:text-gray-400">{{ previewText | safe }}</p>
                  {% endif %}
                {% endif %}
                <div class="mt-1.5">
                  <a href="{{ item.url | url }}" class="text-xs font-medium transition-colors font-sans hover:underline" style="color: var(--accent-color); text-decoration: none;">{% if isSnippet %}View Snippet{% else %}Read Post{% endif %} &rarr;</a>
                </div>
              </div>
              {% if itemImage and item.type == 'post' %}
                <a href="{{ item.url | url }}" class="hidden sm:block shrink-0" style="text-decoration: none;">
                  <img src="{{ itemImage | url }}" alt="{{ itemImageAlt }}" loading="lazy" decoding="async" class="block h-20 w-20 object-contain dark:invert dark:brightness-125">
                </a>
              {% endif %}
            </div>
          {% else %}
            {% if item.summary %}
              <p class="mt-0">{{ item.summary }}</p>
            {% endif %}
          {% endif %}
        </div>

        {# Tags #}
        {% if showTags and item.tags %}
          <div class="flex flex-wrap gap-1.5 mt-5 not-prose">
            {% for tag in item.tags %}
              {% set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
              <a href="{{ tagUrl | url }}" class="badge badge-tag badge-compact badge-interactive font-sans" style="text-decoration: none;">#{{ tag }}</a>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </article>

  {# ── LIST VARIANT (homepage preview - single compact row) ── #}
  {% elif variant == 'list' %}
  <li class="feed-list-row{% if extraClasses %} {{ extraClasses }}{% endif %}" {% if outerAttrs %}{{ outerAttrs | safe }}{% endif %}>
    <span class="feed-list-date meta-text">{{ item.date | shortDate }}</span>
    <span class="badge badge-type badge-compact {{ typeBadgeClass }}">{{ badgeLabel }}</span>
    {% if item.authored_by is defined %}{{ authorshipBadge(item.authored_by, compact=true) }}{% else %}<span></span>{% endif %}
    {% if item.url %}
      <a href="{{ item.url | url }}" class="feed-list-title title-hover">{% if item.featured %}<span style="color: rgb(245 158 11); margin-right: 0.35rem;" title="Featured" aria-label="Featured">★</span>{% endif %}{% if item.pinned %}<span class="inline-flex items-center" style="color: var(--accent-color); margin-right: 0.35rem; margin-top: -2px;" title="Pinned" aria-label="Pinned">{% feather "bookmark", class="w-3.5 h-3.5 fill-current opacity-20" %}</span>{% endif %}{{ item.title }}</a>
    {% else %}
      <span class="feed-list-title">{% if item.featured %}<span style="color: rgb(245 158 11); margin-right: 0.35rem;" title="Featured" aria-label="Featured">★</span>{% endif %}{% if item.pinned %}<span class="inline-flex items-center" style="color: var(--accent-color); margin-right: 0.35rem; margin-top: -2px;" title="Pinned" aria-label="Pinned">{% feather "bookmark", class="w-3.5 h-3.5 fill-current opacity-20" %}</span>{% endif %}{{ item.title }}</span>
    {% endif %}
  </li>

  {# ── FULL VARIANT (feed page - clean card in a grid) ── #}
  {% else %}
  <article class="feed-card feed-card-full surface-compact{% if extraClasses %} {{ extraClasses }}{% endif %}" {% if outerAttrs %}{{ outerAttrs | safe }}{% endif %}>
    {# Header row: type dot + label + date #}
    <div class="flex items-center gap-2 mb-2.5">
      <span class="badge badge-type badge-compact {{ typeBadgeClass }}">{{ badgeLabel }}</span>
      {% if item.featured %}
        <span class="badge badge-featured badge-compact" title="Featured" aria-label="Featured">★ Featured</span>
      {% endif %}
      {% if item.pinned %}
        <span class="badge badge-accent badge-compact flex items-center gap-1" title="Pinned" aria-label="Pinned">{% feather "bookmark", class="w-3 h-3" %} Pinned</span>
      {% endif %}
      {% if item.authored_by is defined %}{{ authorshipBadge(item.authored_by, compact=true) }}{% endif %}
      <time datetime="{{ item.date | htmlDateString }}" class="meta-text text-[0.68rem] text-gray-400 dark:text-gray-500 ml-auto">{{ item.date | readableDate }}</time>
    </div>

    {# Title #}
    {% if not isQuotation %}
    <h3 class="text-sm font-semibold leading-snug text-gray-900 dark:text-gray-100 m-0">
      {% if item.url %}
        <a href="{{ item.url | url }}" class="title-hover" style="color: inherit; text-decoration: none;">{{ item.title }}</a>
      {% else %}
        {{ item.title }}
      {% endif %}
    </h3>
    {% endif %}

    {# Body content #}
    {% if isNote or isNow or isQuotation %}
      {% set contentToRender = item.original.templateContent %}
      {% if contentToRender %}
        {% if isQuotation %}
          <div class="relative mt-2 max-h-44 overflow-hidden">
            <div class="italic border-l-2 pl-3 py-0.5 relative text-xs leading-relaxed text-gray-600 dark:text-gray-300 max-w-none not-prose" style="border-color: var(--accent-color);">
              <span class="absolute left-1 -top-1.5 text-2xl font-serif text-gray-400 opacity-40 leading-none">"</span>
              <div class="relative z-10">{{ contentToRender | safe }}</div>
            </div>
            <div class="feed-card-note-fade absolute bottom-0 left-0 right-0 h-8 pointer-events-none"></div>
          </div>
          <div class="flex flex-col mt-2 shrink-0">
            <span class="font-medium text-gray-900 dark:text-gray-100 text-[0.7rem]">
              - {% if item.original.data.authorUrl %}<a href="{{ item.original.data.authorUrl }}" target="_blank" rel="noopener" class="hover:underline">{{ item.original.data.author }}</a>{% else %}{{ item.original.data.author }}{% endif %}
            </span>
            {% if item.original.data.source %}
              <span class="text-[0.65rem] text-gray-500 mt-0.5 leading-snug">
                {% if item.original.data.sourceUrl %}
                  <a href="{{ item.original.data.sourceUrl }}" target="_blank" rel="noopener" class="hover:underline" style="color: inherit; text-decoration: none;">{{ item.original.data.source }}</a>
                {% else %}
                  {{ item.original.data.source }}
                {% endif %}
              </span>
            {% endif %}
          </div>
        {% else %}
          <div class="relative mt-2 max-h-48 overflow-hidden">
            <div class="text-xs leading-relaxed text-gray-600 dark:text-gray-300 max-w-none not-prose">{{ contentToRender | safe }}</div>
            <div class="feed-card-note-fade absolute bottom-0 left-0 right-0 h-10 pointer-events-none"></div>
          </div>
        {% endif %}
      {% elif item.summary %}
        <p class="mt-1.5 text-xs leading-relaxed text-gray-500 dark:text-gray-400 m-0">{{ item.summary }}</p>
      {% endif %}
    {% elif item.media %}
      <figure class="mt-2 overflow-hidden rounded border border-gray-200 dark:border-gray-700 m-0">
        <img src="{{ item.media.src }}" alt="{{ item.media.alt }}" loading="lazy" decoding="async" class="w-full h-auto block">
        {% if item.summary %}
          <figcaption class="px-2 py-1 text-xs text-gray-500 dark:text-gray-400">{{ item.summary }}</figcaption>
        {% endif %}
      </figure>
    {% elif item.summary and showSummary %}
      {% if itemImage and item.type == 'post' %}
        <div class="mt-2 flex items-start gap-3">
          <p class="min-w-0 flex-1 text-xs leading-relaxed text-gray-500 dark:text-gray-400 m-0">{{ item.summary }}</p>
          <a href="{{ item.url | url }}" class="shrink-0" style="text-decoration: none;">
            <img src="{{ itemImage | url }}" alt="{{ itemImageAlt }}" loading="lazy" decoding="async" class="block h-24 w-24 object-contain dark:invert dark:brightness-125">
          </a>
        </div>
      {% else %}
        <p class="mt-1.5 text-xs leading-relaxed text-gray-500 dark:text-gray-400 m-0">{{ item.summary }}</p>
      {% endif %}
    {% endif %}

    {# Tags #}
    {% if showTags and item.tags %}
      <div class="flex flex-wrap gap-1 mt-2.5">
        {% for tag in item.tags %}
          {% set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
          <a href="{{ tagUrl | url }}" class="badge badge-tag badge-compact badge-interactive" style="text-decoration: none;">#{{ tag }}</a>
        {% endfor %}
      </div>
    {% endif %}
  </article>
  {% endif %}
{% endmacro %}
