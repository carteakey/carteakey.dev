{% if steam and steam.length > 0 %}
  <div class="steam-snippet space-y-3">
    <h3 class="editorial-kicker">Latest Games</h3>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {% for game in steam | head(3) %}
        <article class="feed-card-full flex flex-col overflow-hidden p-0">
          <img src="{{ game.library_hero }}" alt="{{ game.name }} hero" loading="lazy" decoding="async" class="h-36 w-full object-cover">
          <div class="flex flex-col gap-1.5 p-3 text-center">
            <a href="{{ game.url }}" target="_blank" rel="noopener noreferrer" class="editorial-title-link-compact">
              {{ game.name }}
            </a>
            <p class="meta-text text-[0.65rem] text-gray-400 dark:text-gray-500 m-0">
              {% if game.playtime_2weeks > 0 %}{{ game.playtime_2weeks }}h last 2 weeks{% endif %}
              {% if game.playtime_forever > 0 %}{% if game.playtime_2weeks > 0 %} · {% endif %}{{ game.playtime_forever }}h total{% endif %}
            </p>
          </div>
        </article>
      {% endfor %}
    </div>
    <p class="m-0"><a href="/games" class="editorial-meta-link">View all games →</a></p>
  </div>
{% endif %}
