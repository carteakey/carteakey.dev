---
layout: layouts/base.njk
---
{% include "components/breadcrumbs.njk" %}
{% from "components/authorship-badge.njk" import authorshipBadge %}

<article class="site-content">
  <header class="not-prose mb-4">
    <div class="flex items-center gap-2 mb-1">
      <span class="inline-block w-1.5 h-1.5 rounded-full bg-purple-400"></span>
      <span class="meta-text text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wide">Note</span>
      <time datetime="{{ page.date | htmlDateString }}" class="meta-text text-xs text-gray-400 dark:text-gray-500">· {{ page.date | readableDate }}</time>
      {{ authorshipBadge(authored_by) }}
    </div>
    <h1 class="text-2xl font-semibold tracking-tight mt-1">{{ title }}</h1>
  </header>

  <div>
    {{ content | safe }}
  </div>

  <footer class="not-prose mt-8 pt-4 border-t border-gray-200 dark:border-gray-800">
    <a href="{{ '/feed/' | url }}" class="text-sm text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" style="text-decoration: none;">← Back to feed</a>
  </footer>
</article>
