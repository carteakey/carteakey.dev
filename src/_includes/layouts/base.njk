              <li><a href="{{ '/feed' | url }}" class="inline-flex items-center gap-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">{% feather "activity", class="w-3 h-3 shrink-0" %} Feed</a></li>
              <li><a href="{{ '/blog' | url }}" class="inline-flex items-center gap-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">{% feather "edit-3", class="w-3 h-3 shrink-0" %} Blog</a></li>
              <li><a href="{{ '/snippets' | url }}" class="inline-flex items-center gap-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">{% feather "code", class="w-3 h-3 shrink-0" %} Snippets</a></li>
              <li><a href="{{ '/about' | url }}" class="inline-flex items-center gap-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">{% feather "user", class="w-3 h-3 shrink-0" %} About</a></li>
              <li><a href="{{ '/quotations' | url }}" class="inline-flex items-center gap-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">{% feather "message-circle", class="w-3 h-3 shrink-0" %} Quotations</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold text-gray-400 dark:text-gray-500 mb-1 text-[0.6rem] uppercase tracking-wider">Explore</h4>
            <ul class="space-y-1 list-none m-0 p-0">
