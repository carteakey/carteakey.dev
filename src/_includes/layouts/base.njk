              <li><a href="{{ '/prompts' | url }}" class="inline-flex items-center gap-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">{% feather "terminal", class="w-3 h-3 shrink-0" %} Prompts</a></li>
              <li><a href="{{ '/gallery' | url }}" class="inline-flex items-center gap-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">{% feather "image", class="w-3 h-3 shrink-0" %} Gallery</a></li>
              <li><a href="{{ '/folio' | url }}" class="inline-flex items-center gap-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">{% feather "layers", class="w-3 h-3 shrink-0" %} Folio</a></li>
              <li><a href="{{ '/data' | url }}" class="inline-flex items-center gap-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">{% feather "bar-chart-2", class="w-3 h-3 shrink-0" %} Data</a></li>
              <li><a href="{{ '/listening' | url }}" class="inline-flex items-center gap-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">{% feather "headphones", class="w-3 h-3 shrink-0" %} Listening</a></li>
              <li><a href="{{ '/search' | url }}" class="inline-flex items-center gap-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">{% feather "search", class="w-3 h-3 shrink-0" %} Search</a></li>
              <li><a href="{{ '/stats' | url }}" class="inline-flex items-center gap-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">{% feather "bar-chart", class="w-3 h-3 shrink-0" %} Stats</a></li>
              <li><a href="{{ '/guestbook' | url }}" class="inline-flex items-center gap-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">{% feather "message-square", class="w-3 h-3 shrink-0" %} Guestbook</a></li>
            </ul>
          </div>
        </div>

        {# Desktop: 4-column categorized grid #}
        <div class="hidden md:grid grid-cols-4 gap-x-4 gap-y-2 text-xs">
          
          {# Read - content for others #}
          <div>
            <h4 class="font-semibold text-gray-500 dark:text-gray-500 mb-1 text-[0.65rem] uppercase tracking-wider">Read</h4>
