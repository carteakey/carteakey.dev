<!DOCTYPE html>
<html lang="{{ metadata.language }}" class="scroll-smooth">

<head>
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="manifest" href="/site.webmanifest" />

  {# Using locally hosted fonts (Plus Jakarta Sans + ET Book). Inter CDN removed. #}
  {# <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/default.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script> #}
  {# Moved away from Google Fonts to self-hosted fonts #}
  {# Moved away from PrismJS to highlight.js #}
  {# <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Caveat&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@100;200;300;400&display=swap" rel="stylesheet">
  {# \u003cscript\u003ehljs.highlightAll();\u003c/script\u003e #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&family=Caveat:wght@400;500;700&display=swap" rel="stylesheet">
  <meta name="generator" content="Eleventy">
  <link id="prism-theme" href="/static/css/prism/prism-light.css" rel="stylesheet"/>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-DKK1XXJY42"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag() {
      dataLayer.push(arguments);
    }
    gtag("js", new Date());

    gtag("config", "G-DKK1XXJY42");
  </script>

  <script src="/static/js/theme.js"></script>
  
  <script defer src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <script defer src="/static/js/alpine.min.js"></script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#14b8a6" id="theme-color-meta">
  <title>{{ title or metadata.title }}</title>
  <meta name="description" content="{{ description or metadata.description }}" />
  <meta name="generator" content="{{ eleventy.generator }}" />
  
  {# Open Graph / Facebook Meta Tags #}
  <meta property="og:type" content="{% if templateClass == 'tmpl-post' %}article{% else %}website{% endif %}" />
  <meta property="og:url" content="{{ page.url | absoluteUrl(metadata.url) }}" />
  <meta property="og:site_name" content="{{ metadata.title }}" />
  <meta property="og:title" content="{{ title or metadata.title }}" />
  <meta property="og:description" content="{{ description or metadata.description }}" />
  {% if image %}
  <meta property="og:image" content="{{ image | absoluteUrl(metadata.url) }}" />
  {% else %}
  <meta property="og:image" content="{{ '/img/avatar.png' | absoluteUrl(metadata.url) }}" />
  {% endif %}
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="en_US" />
  
  {# Article specific Open Graph tags #}
  {% if templateClass == 'tmpl-post' %}
  <meta property="article:published_time" content="{{ page.date | htmlDateString }}" />
  {% if updated %}
  <meta property="article:modified_time" content="{{ updated | htmlDateString }}" />
  {% endif %}
  <meta property="article:author" content="{{ metadata.author.name }}" />
  {% for tag in tags | filterTagList %}
  <meta property="article:tag" content="{{ tag }}" />
  {% endfor %}
  {% endif %}
  
  {# Twitter Card Meta Tags #}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content="{{ page.url | absoluteUrl(metadata.url) }}" />
  <meta name="twitter:title" content="{{ title or metadata.title }}" />
  <meta name="twitter:description" content="{{ description or metadata.description }}" />
  {% if image %}
  <meta name="twitter:image" content="{{ image | absoluteUrl(metadata.url) }}" />
  {% else %}
  <meta name="twitter:image" content="{{ '/img/avatar.png' | absoluteUrl(metadata.url) }}" />
  {% endif %}
  <meta name="twitter:creator" content="@carteakey" />
  <meta name="twitter:site" content="@carteakey" />
  
  {# Additional SEO Meta Tags #}
  <meta name="author" content="{{ metadata.author.name }}" />
  <link rel="canonical" href="{{ page.url | absoluteUrl(metadata.url) }}" />
  
  <link rel="stylesheet" href="{{ '/css/tailwind.css' | url }}" />

  <link rel="alternate" type="application/atom+xml" title="{{ metadata.title }} - Atom Feed" href="{{ '/feed.xml' | url }}">
  
  {# JSON-LD Structured Data for Website #}
  {% if page.url == "/" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "{{ metadata.title }}",
    "url": "{{ metadata.url }}",
    "description": "{{ metadata.description }}",
    "author": {
      "@type": "Person",
      "name": "{{ metadata.author.name }}",
      "email": "{{ metadata.author.email }}",
      "url": "{{ metadata.author.url }}"
    },
    "publisher": {
      "@type": "Person",
      "name": "{{ metadata.author.name }}",
      "url": "{{ metadata.url }}"
    },
    "potentialAction": {
      "@type": "SearchAction",
      "target": "{{ metadata.url }}/search?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
  {% endif %}
</head>
{% set showReadingFrame = false %}
<body class="bg-gray-100 dark:bg-black font-sans text-sm">
  {# Skip to main content link for accessibility #}
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:rounded-md focus:font-semibold focus:text-black" style="background: var(--accent-color);">
    Skip to main content
  </a>
  
  <div
   class="md:max-w-2xl lg:max-w-3xl xl:max-w-4xl mx-auto {% if showReadingFrame %} md:bg-gray-100/95  md:dark:bg-zinc-950/90 md:shadow-[0_20px_60px_-28px_rgba(15,23,42,0.45)] md:dark:shadow-[0_16px_50px_-26px_rgba(0,0,0,0.65)] md:ring-1 md:ring-amber-100/40 md:dark:ring-zinc-800/40 md:px-28 lg:px-32 md:py-10 md:rounded-none{% endif %}">
    <div class="site-content px-4 md:px-0">
      <nav class="not-prose flex w-full py-3.5 border-b border-gray-200 dark:border-gray-800 mb-4">

        {% set navPages = collections.all | eleventyNavigation %}

        <div class="flex flex-row w-full justify-between items-center gap-4">

          {# Site title - same on desktop and mobile, consistent font #}
          <a class="no-underline hover:no-underline font-bold text-base tracking-tight group flex items-center shrink-0" href="{{ '/' | url }}" style="color: var(--accent-color)">
            carteakey.dev
          </a>

          <ul class="list-none m-0 p-0 flex items-center gap-2">
            {# Main navigation items #}
            {%- for entry in navPages %}
              {% if entry.title == "About" or entry.title == "Blog" or entry.title == "Now" %}
                <li class="px-2 sm:px-2.5 py-1 transition-all hidden sm:flex items-center">
                  <a class="font-medium no-underline link-glow text-base" href="{{ entry.url }}">{{ entry.title }}</a>
                </li>
              {% endif %}
            {%- endfor %}

            <li class="flex items-center">
              <a class="font-medium no-underline inline-flex items-center justify-center p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" href="{{ '/search/' | url }}" title="Search" aria-label="Search" style="color: var(--accent-color)">
                {% feather "search", class="w-4 h-4" %}
              </a>
            </li>

            <li class="flex items-center">
              <a class="font-medium no-underline inline-flex items-center justify-center p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" href="{{ '/more/' | url }}" title="More pages" aria-label="More pages" style="color: var(--accent-color)">
                {% feather "compass", class="w-4 h-4" %}
              </a>
            </li>

            {# Accent theme slider - inline in nav, always visible #}
            <li class="flex items-center ml-1" x-data="{
              currentIndex: 12,
              themes: [
                { name: 'gray',    hex: '#6b7280' },
                { name: 'slate',   hex: '#64748b' },
                { name: 'zinc',    hex: '#71717a' },
                { name: 'neutral', hex: '#737373' },
                { name: 'stone',   hex: '#78716c' },
                { name: 'red',     hex: '#ef4444' },
                { name: 'orange',  hex: '#f97316' },
                { name: 'amber',   hex: '#f59e0b' },
                { name: 'yellow',  hex: '#eab308' },
                { name: 'lime',    hex: '#84cc16' },
                { name: 'green',   hex: '#22c55e' },
                { name: 'emerald', hex: '#10b981' },
                { name: 'teal',    hex: '#14b8a6' },
                { name: 'cyan',    hex: '#06b6d4' },
                { name: 'sky',     hex: '#0ea5e9' },
                { name: 'blue',    hex: '#3b82f6' },
                { name: 'indigo',  hex: '#6366f1' },
                { name: 'violet',  hex: '#8b5cf6' },
                { name: 'purple',  hex: '#a855f7' },
                { name: 'fuchsia', hex: '#d946ef' },
                { name: 'pink',    hex: '#ec4899' },
                { name: 'rose',    hex: '#f43f5e' }
              ],
              init() {
                const saved = localStorage.accentTheme || 'teal';
                const idx = this.themes.findIndex(t => t.name === saved);
                this.currentIndex = idx === -1 ? 12 : idx;
              },
              pick(i) {
                this.currentIndex = i;
                window.setAccentTheme(this.themes[i].name);
              }
            }" x-init="init()">
              {# Mobile: tap colored dot to cycle accent color #}
              <button class="sm:hidden w-4 h-4 rounded-full border-2 border-white/60 shadow flex-shrink-0"
                :style="`background-color: ${themes[currentIndex].hex}; border-color: ${themes[currentIndex].hex}`"
                @click="pick((currentIndex + 1) % themes.length)"
                :title="`Accent: ${themes[currentIndex].name} (tap to cycle)`"></button>
              {# Desktop: gradient slider #}
              <div class="hidden sm:block relative w-28 h-4 rounded-full overflow-hidden cursor-pointer" style="background: linear-gradient(to right, #6b7280,#64748b,#71717a,#737373,#78716c,#ef4444,#f97316,#f59e0b,#eab308,#84cc16,#22c55e,#10b981,#14b8a6,#06b6d4,#0ea5e9,#3b82f6,#6366f1,#8b5cf6,#a855f7,#d946ef,#ec4899,#f43f5e);">
                <div class="absolute top-0 h-full w-0.5 -translate-x-1/2 bg-white/80 rounded pointer-events-none transition-all duration-150"
                     :style="`left: ${(currentIndex / (themes.length - 1)) * 100}%`"></div>
                <input type="range" min="0" :max="themes.length - 1" :value="currentIndex"
                       @input="pick(parseInt($event.target.value))"
                       class="absolute inset-0 w-full h-full opacity-0 cursor-pointer">
              </div>
            </li>

            <li class="flex items-center">
              <button id="toggleDarkMode" class="font-medium text-xs p-2 transition-all rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 focus-ring inline-flex items-center justify-center" aria-label="Toggle dark mode" style="color: var(--accent-color)">
                {% feather "moon" , class="block dark:hidden w-4 h-4" %}
                {% feather "sun" , class="hidden dark:block w-4 h-4"%}
              </button>
            </li>
          </ul>

        </div>

      </nav>

      <main id="main-content" class="{% if fullWidth %}-mx-[calc(50vw-50%)] w-screen px-4 md:px-8{% endif %} {% if templateClass %}{{ templateClass }}{% endif %}">

        {{ content | safe }}

          <script>
            document
              .getElementById("toggleDarkMode")
              .addEventListener("click", function () {
                if (isDarkMode()) {
                  localStorage.theme = "light";
                  document.documentElement.classList.remove("dark");
                } else {
                  localStorage.theme = "dark";
                  document.documentElement.classList.add("dark");
                }
                switchPrismTheme();
                if (typeof window.syncThemeColorMeta === "function") {
                  window.syncThemeColorMeta();
                }
              });

          </script>
      </main>

      <footer class="not-prose flex w-full pt-4 pb-2 flex-col md:flex-row justify-between items-center gap-3 border-t border-gray-200 dark:border-gray-700 mt-8">
        {% if spotify.nowPlaying %}
        <div class="flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400 not-prose">
          <img id="track-image" class="w-5 h-5 rounded-full animate-spin-slow"
            src="{{ spotify.nowPlaying.albumImageUrl }}" alt="{{ spotify.nowPlaying.title }}" width="20" height="20" loading="lazy">
          <span>Now playing:</span>
          <a href={{ spotify.nowPlaying.songUrl }} target='_blank' class='hover:underline text-gray-700 dark:text-gray-300 font-medium'>{{ spotify.nowPlaying.title }}</a>
          <span class="text-gray-400 dark:text-gray-600">- {{ spotify.nowPlaying.artist }}</span>
        </div>
        {% else %}
        <div></div>
        {% endif %}
        <div class='flex items-center gap-1 not-prose'>
          <a class="p-1.5 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-all text-gray-500 dark:text-gray-400" href="https://www.linkedin.com/in/kartikeychauhan/" title="LinkedIn" aria-label="LinkedIn">{% feather "linkedin", class="w-4 h-4" %}</a>
          <a class="p-1.5 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-all text-gray-500 dark:text-gray-400" href="https://github.com/carteakey" title="GitHub" aria-label="GitHub">{% feather "github", class="w-4 h-4" %}</a>
          <span class="text-gray-300 dark:text-gray-600">|</span>
          <a class="p-1.5 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-all text-gray-500 dark:text-gray-400" href="{{ '/search/' | url }}" title="Search" aria-label="Search">{% feather "search", class="w-4 h-4" %}</a>
          <a class="p-1.5 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-all text-gray-500 dark:text-gray-400" href="{{ '/feed.xml' | url }}" title="RSS" aria-label="RSS">{% feather "rss", class="w-4 h-4" %}</a>
          <a class="p-1.5 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-all text-gray-500 dark:text-gray-400" href="{{ '/newsletter/' | url }}" title="Newsletter" aria-label="Newsletter">{% feather "mail", class="w-4 h-4" %}</a>
        </div>
      </footer>


      {# Extended footer section #}
      <div class="border-t border-gray-200 dark:border-gray-700 pt-4 pb-6 not-prose">

        {# Categorized footer navigation - 4-col on md+; flat link list on mobile #}

        {# Mobile: 2-col compact grid with category headings + icons #}
        <div class="grid grid-cols-2 gap-x-4 gap-y-3 text-xs md:hidden">
