              <li><a href="{{ '/notes' | url }}" class="inline-flex items-center gap-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">{% feather "file-text", class="w-3 h-3 shrink-0" %} Notes</a></li>
