            </ul>
          </div>

          {# Explore - creative & fun #}
          <div>
            <h4 class="font-semibold text-gray-500 dark:text-gray-500 mb-1 text-[0.65rem] uppercase tracking-wider">Explore</h4>
            <ul class="space-y-0.5 list-none m-0 p-0">
              <li><a href="{{ '/projects' | url }}" class="inline-flex items-center gap-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">{% feather "box", class="w-3 h-3 shrink-0" %} Projects</a></li>
              <li><a href="{{ '/prompts' | url }}" class="inline-flex items-center gap-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">{% feather "terminal", class="w-3 h-3 shrink-0" %} Prompts</a></li>
              <li><a href="{{ '/gallery' | url }}" class="inline-flex items-center gap-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">{% feather "image", class="w-3 h-3 shrink-0" %} Gallery</a></li>
              <li><a href="{{ '/folio' | url }}" class="inline-flex items-center gap-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors">{% feather "layers", class="w-3 h-3 shrink-0" %} Folio</a></li>
