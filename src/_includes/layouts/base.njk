        <tr><td style="padding:0.2rem 0;white-space:nowrap;"><kbd style="background:#f3f4f6;border:1px solid #d1d5db;border-radius:3px;padding:1px 5px;font-size:0.7rem;font-family:monospace;">D</kbd></td><td style="padding:0.2rem 0 0.2rem 1rem;color:#374151;" class="dark:text-gray-300">Toggle dark mode</td></tr>
        <tr><td style="padding:0.2rem 0;"><kbd style="background:#f3f4f6;border:1px solid #d1d5db;border-radius:3px;padding:1px 5px;font-size:0.7rem;font-family:monospace;">?</kbd></td><td style="padding:0.2rem 0 0.2rem 1rem;color:#374151;" class="dark:text-gray-300">This overlay</td></tr>
      </table>
    </div>
  </div>
  <script>
  (function() {
    const nav = { h:'/', b:'/blog/', f:'/feed/', s:'/snippets/', n:'/now/', t:'/til/', r:'/reading/' };
    document.addEventListener('keydown', function(e) {
      if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.isContentEditable) return;
      // No modifier keys - bare letter shortcuts only (allow Shift for ? key)
      if (e.ctrlKey || e.metaKey || e.altKey) return;
      if (e.shiftKey && e.key !== '?') return;
      const k = e.key.toLowerCase();
      if (nav[k]) { window.location.href = nav[k]; return; }
      if (k === 'd') { document.getElementById('toggleDarkMode')?.click(); return; }
      if (k === '/') { e.preventDefault(); window.location.href = '/search/'; return; }
      if (e.key === '?') {
        const o = document.getElementById('shortcuts-overlay');
        o.style.display = o.style.display === 'none' ? 'flex' : 'none';
        return;
      }
      if (e.key === 'Escape') { document.getElementById('shortcuts-overlay').style.display = 'none'; }
    });
  })();
  </script>

