---
layout: layouts/base.njk
---

{% include "components/breadcrumbs.njk" %}
{% from "components/authorship-badge.njk" import authorshipBadge %}

<header class="not-prose mb-4">
  <div class="flex items-center gap-2 mb-1">
    <span class="inline-block w-1.5 h-1.5 rounded-full bg-yellow-400"></span>
    <span class="meta-text text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wide">TIL</span>
    <time datetime="{{ page.date | htmlDateString }}" class="meta-text text-xs text-gray-400 dark:text-gray-500">· {{ page.date | readableDate }}</time>
    {% if source %}
      <span class="meta-text text-xs text-gray-400 dark:text-gray-500">· <a href="{{ source }}" target="_blank" rel="noopener" class="title-hover">Source ↗</a></span>
    {% endif %}
    {{ authorshipBadge(authored_by) }}
  </div>
  <h1 class="text-2xl font-semibold tracking-tight mt-1 m-0">{{ title }}</h1>
</header>

<div class="flex justify-end mt-4 mb-2">
  {% include "components/copy-markdown.njk" %}
</div>

<article class="site-content">
  {{ content | safe }}
</article>

<footer class="not-prose mt-8 pt-4 border-t border-gray-200 dark:border-gray-800">
  <a href="{{ '/til/' | url }}" class="text-sm text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" style="text-decoration: none;">← All TILs</a>
</footer>
