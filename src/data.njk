---
layout: layouts/base.njk
title: My life in data
description: A scrollable dashboard generated from cartebase — personal data from Spotify, Apple Photos, and browsing history.
permalink: /data/
eleventyExcludeFromCollections: true
---

{% include "components/breadcrumbs.njk" %}
{% import "components/cartebase-charts.njk" as cb %}

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>

{% set startYear = (cartebase.summary.data_starts_at | split('-'))[0] %}
{% set endYear = (cartebase.summary.data_ends_at | split('-'))[0] %}
{% set topArtist = cartebase.listening.top_artists_all_time[0] %}
{% set topDomain = cartebase.browsing.top_domains_all_time[0] %}
{% set totalMinutes = cartebase.listening.minutes_total %}

{% set pageTitle = "My life in data" %}
{% set pageMeta = "Updated " ~ (cartebase.summary.last_updated | split('T'))[0] %}
{% set pageDescription = "A scrollable dashboard generated from <a href=\"https://github.com/carteakey/cartebase\" class=\"accent-link\">cartebase</a>, a Dogsheep-style SQLite warehouse of my personal data, spanning <strong>" ~ startYear ~ "–" ~ endYear ~ "</strong>. Inspired by <a href=\"https://howisfelix.today/\" class=\"accent-link\">howisFelix.today</a>. Finance, health, shopping, and private domains are deliberately excluded." %}
{% include "components/page-header.njk" %}

<div class="not-prose grid grid-cols-2 md:grid-cols-4 gap-3 mb-8">
  {{ cb.stat_tile("Spotify plays", cartebase.summary.plays_total | localeNumber, "since " + startYear) }}
  {{ cb.stat_tile("Minutes listened", totalMinutes | round(0) | localeNumber) }}
  {{ cb.stat_tile("Photos", cartebase.summary.photos_total | localeNumber) }}
  {{ cb.stat_tile("Browsing visits", cartebase.summary.browsing_visits_total | localeNumber) }}
</div>

{{ cb.section_header("Music", "Spotify listening history", "music") }}

<div class="not-prose mb-6">
  {{ cb.wrapped_card(
    label="My top artist",
    title=topArtist.artist,
    subtitle="I've played " + topArtist.artist + " more than any other artist — " + (topArtist.share_pct | string) + "% of every track I've streamed.",
    stats=[
      {"label": "Plays", "value": topArtist.plays | localeNumber},
      {"label": "Minutes", "value": topArtist.minutes | round(0) | localeNumber},
      {"label": "Share of all plays", "value": (topArtist.share_pct | string) + "%"}
    ],
    image="/img/radiohead-hero.jpg",
    image_alt="Spotify Wrapped 2025: My Top Artist — Radiohead"
  ) }}
</div>

<div class="not-prose mb-4">
  <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-2">Plays per month</h3>
  {{ cb.line_chart("chart_plays_per_month", cartebase.listening.plays_per_month | map('month'), cartebase.listening.plays_per_month | map('plays'), "Plays", height=180) }}
</div>

<div class="not-prose mb-4">
  <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-2">Artist share over time</h3>
  <p class="text-xs text-gray-500 dark:text-gray-400 mb-2">
    The artists that cracked any year's top 10, as a percentage of that year's plays. "Other" is the long tail — even my most-played artists rarely account for more than a quarter of a year. Watch Radiohead climb after 2024.
  </p>
  {{ cb.stacked_area("chart_artist_share", cartebase.listening.artist_share_per_year.years, cartebase.listening.artist_share_per_year.series, height=360) }}
</div>

<div class="not-prose mb-4">
  <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-2">Listening rhythm (hour × weekday, UTC)</h3>
  {{ cb.heatmap(cartebase.listening.hour_weekday_heatmap) }}
</div>

<p class="text-xs text-gray-500 dark:text-gray-400 mt-2 not-prose">
  <a href="/listening/" class="accent-link">Top albums, tracks, year-in-review → /listening/</a>
</p>

{{ cb.section_header("Web", "Browsing history + bookmarks", "globe") }}

<div class="not-prose mb-6">
  {{ cb.wrapped_card(
    label="Most-visited domain",
    title=topDomain.domain,
    subtitle="Nearly " + (topDomain.share_pct | string) + "% of my recorded web visits land on " + topDomain.domain + ".",
    stats=[
      {"label": "Visits", "value": topDomain.visits | localeNumber},
      {"label": "Share of traffic", "value": (topDomain.share_pct | string) + "%"},
      {"label": "Distinct domains tracked", "value": (cartebase.browsing.top_domains_all_time | length) | string + "+"}
    ]
  ) }}
</div>

<div class="not-prose mb-4">
  <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-2">Visits per month</h3>
  {{ cb.line_chart("chart_visits_per_month", cartebase.browsing.visits_per_month | map('month'), cartebase.browsing.visits_per_month | map('visits'), "Visits", height=180) }}
</div>

<div class="not-prose mb-4">
  <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-2">Top domains — all time</h3>
  {{ cb.share_bars(cartebase.browsing.top_domains_all_time, "domain", "visits", cartebase.summary.browsing_visits_total, limit=10) }}
</div>

<div class="not-prose mt-6 pt-4 border-t border-gray-200 dark:border-zinc-800">
  <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-2">Bookmarks</h3>
  <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">
    {{ cartebase.summary.bookmarks_total | localeNumber }} bookmarks canonicalised — of those,
    <strong>{{ cartebase.bookmarks.with_notes_count | localeNumber }}</strong>
    have notes attached, a hint at which ones might graduate to the blogmarks feed someday.
  </p>
  <details class="text-xs">
    <summary class="cursor-pointer text-gray-500 hover:text-gray-700 dark:hover:text-gray-300">Top bookmark domains</summary>
    <div class="mt-2 grid grid-cols-2 md:grid-cols-3 gap-x-4 gap-y-1">
      {% for d in cartebase.bookmarks.top_domains | head(15) %}
        <div class="flex justify-between text-xs">
          <span class="text-gray-700 dark:text-gray-300 truncate">{{ d.domain }}</span>
          <span class="text-gray-400 tabular-nums">{{ d.count | localeNumber }}</span>
        </div>
      {% endfor %}
    </div>
  </details>
</div>

{{ cb.section_header("Gaming", "Steam library — " + cartebase.gaming.games_played | string + " of " + cartebase.gaming.games_owned | string + " games actually touched", "monitor") }}

<div class="not-prose grid grid-cols-2 md:grid-cols-3 gap-3 mb-4">
  {{ cb.stat_tile("Hours logged", cartebase.gaming.total_hours | round(0) | localeNumber) }}
  {{ cb.stat_tile("Games played", cartebase.gaming.games_played | localeNumber, "of " + cartebase.gaming.games_owned | string + " owned") }}
  {{ cb.stat_tile("Avg / game played", (cartebase.gaming.total_hours / cartebase.gaming.games_played) | round(1) | string + " h") }}
</div>

<div class="not-prose mb-4">
  <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-2">Top games by hours</h3>
  {{ cb.share_bars(cartebase.gaming.top_games, "name", "hours", cartebase.gaming.total_hours, limit=10) }}
</div>

{{ cb.section_header("Photos", "Apple Photos library", "camera") }}

<div class="not-prose mb-4">
  <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-2">Photos captured per month</h3>
  {{ cb.line_chart("chart_photos_per_month", cartebase.photos.photos_per_month | map('month'), cartebase.photos.photos_per_month | map('count'), "Photos", height=180) }}
</div>

<div class="mt-12 border-t border-gray-200 dark:border-zinc-800 pt-6 text-xs text-gray-500 dark:text-gray-400 not-prose">
  <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-2">About this page</h3>
  <p class="mb-2">
    Generated at build time from JSON snapshots exported out of
    <a href="https://github.com/carteakey/cartebase" class="accent-link">cartebase</a>,
    a personal SQLite-for-life data warehouse inspired by
    <a href="https://dogsheep.github.io/" class="accent-link">Simon Willison's Dogsheep</a>
    and <a href="https://howisfelix.today/" class="accent-link">Felix Krause's howisFelix.today</a>.
  </p>
  <p class="mb-2">
    Aggregates only — no row-level personal data ships to the web. Portfolio, finance, health,
    and shopping data are deliberately excluded. Browsing history is filtered to drop
    localhost/internal domains and only aggregate counts appear.
  </p>
  <p>
    A public Datasette instance at <code>datasette.carteakey.dev</code> is a planned follow-up.
  </p>
</div>
