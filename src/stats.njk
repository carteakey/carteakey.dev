---
layout: layouts/base.njk
title: Stats
description: Numbers and insights about this site.
eleventyNavigation:
  key: Stats
  order: 9
permalink: /stats/
---

{% include "components/breadcrumbs.njk" %}

{% set pageTitle = "Stats" %}
{% set pageDescription = "Numbers. Updated every build." %}
{% include "components/page-header.njk" %}

{# ── Compute stats using filters ── #}
{% set totalWords = collections.posts | sumWordCounts %}
{% set avgWords = 0 %}
{% if collections.posts.length > 0 %}
  {% set avgWords = (totalWords / collections.posts.length) | round %}
{% endif %}
{% set byYear = collections.posts | countByYear %}
{% set years = byYear | keys | sort | reverse %}
{% set maxPerYear = 1 %}
{% for yr in years %}
  {% if byYear[yr] > maxPerYear %}{% set maxPerYear = byYear[yr] %}{% endif %}
{% endfor %}

{% set currentYear = "now" | date("Y") %}
{% set currentMonth = "now" | date("n") %}
{% set postsThisYear = byYear[currentYear] | default(0) %}
{% set postsThisMonth = collections.posts | countInYearMonth(currentYear, currentMonth) %}

{% set totalUpvotes = 0 %}
{% for slug, count in upvotes.posts %}
  {% set totalUpvotes = totalUpvotes + count %}
{% endfor %}

{# ── Hero numbers ── #}
<div class="not-prose grid grid-cols-2 sm:grid-cols-4 divide-x divide-y sm:divide-y-0 divide-gray-200 dark:divide-gray-800 border border-gray-200 dark:border-gray-800 rounded-lg overflow-hidden mb-8">
  <div class="p-4 text-center">
    <div class="text-3xl sm:text-4xl font-black tracking-tight" style="color: var(--accent-color)">{{ collections.posts.length }}</div>
    <div class="text-xs text-gray-500 dark:text-gray-400 mt-1 uppercase tracking-wide">Posts</div>
  </div>
  <div class="p-4 text-center">
    <div class="text-3xl sm:text-4xl font-black tracking-tight" style="color: var(--accent-color)">{{ collections.snippets.length }}</div>
    <div class="text-xs text-gray-500 dark:text-gray-400 mt-1 uppercase tracking-wide">Snippets</div>
  </div>
  <div class="p-4 text-center">
    <div class="text-3xl sm:text-4xl font-black tracking-tight" style="color: var(--accent-color)">
      {% if totalWords > 1000 %}{{ (totalWords / 1000) | round(1) }}k{% else %}{{ totalWords }}{% endif %}
    </div>
    <div class="text-xs text-gray-500 dark:text-gray-400 mt-1 uppercase tracking-wide">Words</div>
  </div>
  <div class="p-4 text-center">
    <div class="text-3xl sm:text-4xl font-black tracking-tight" style="color: var(--accent-color)">{{ totalUpvotes }}</div>
    <div class="text-xs text-gray-500 dark:text-gray-400 mt-1 uppercase tracking-wide">Upvotes</div>
  </div>
</div>

{# ── Two-column: writing rows | posts-per-year bars ── #}
<div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">

  <div>
    <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-3">Writing</h2>
    <div class="divide-y divide-gray-100 dark:divide-gray-800/80">

      <div class="py-2.5 flex items-baseline justify-between">
        <span class="text-sm text-gray-600 dark:text-gray-400">Total words</span>
        <span class="meta-text text-sm font-semibold text-gray-900 dark:text-gray-100">{{ totalWords | numberString }}</span>
      </div>

      <div class="py-2.5 flex items-baseline justify-between">
        <span class="text-sm text-gray-600 dark:text-gray-400">Avg words / post</span>
        <span class="meta-text text-sm font-semibold text-gray-900 dark:text-gray-100">{{ avgWords | numberString }}</span>
      </div>

      <div class="py-2.5 flex items-baseline justify-between">
        <span class="text-sm text-gray-600 dark:text-gray-400">Posts this year</span>
        <span class="meta-text text-sm font-semibold text-gray-900 dark:text-gray-100">{{ postsThisYear }}</span>
      </div>

      <div class="py-2.5 flex items-baseline justify-between">
        <span class="text-sm text-gray-600 dark:text-gray-400">Posts this month</span>
        <span class="meta-text text-sm font-semibold text-gray-900 dark:text-gray-100">{{ postsThisMonth }}</span>
      </div>

      {% set latestPost = collections.posts | sortByDate | first %}
      {% if latestPost %}
      <div class="py-2.5 flex items-baseline justify-between gap-2">
        <span class="text-sm text-gray-600 dark:text-gray-400 shrink-0">Latest</span>
        <a href="{{ latestPost.url }}" class="text-xs text-gray-500 dark:text-gray-400 title-hover text-right truncate min-w-0" style="text-decoration:none;">{{ latestPost.data.title }}</a>
      </div>
      {% endif %}

      <div class="py-2.5 flex items-baseline justify-between">
        <span class="text-sm text-gray-600 dark:text-gray-400">Post tags</span>
        <span class="meta-text text-sm font-semibold text-gray-900 dark:text-gray-100">{{ collections.tagList.length }}</span>
      </div>

      <div class="py-2.5 flex items-baseline justify-between">
        <span class="text-sm text-gray-600 dark:text-gray-400">Snippet languages</span>
        <span class="meta-text text-sm font-semibold text-gray-900 dark:text-gray-100">{{ collections.snippets | map('data.language') | uniq | length }}</span>
      </div>

      <div class="py-2.5 flex items-baseline justify-between">
        <span class="text-sm text-gray-600 dark:text-gray-400">Total pages</span>
        <span class="meta-text text-sm font-semibold text-gray-900 dark:text-gray-100">{{ collections.all.length }}</span>
      </div>

      <div class="py-2.5 flex items-baseline justify-between">
        <span class="text-sm text-gray-600 dark:text-gray-400">Last build</span>
        <span class="meta-text text-xs text-gray-500">{{ page.date | readableDate }} · {{ page.date | date('h:mm a') }}</span>
      </div>

    </div>
  </div>

  {# Posts per year bar chart #}
  <div>
    <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-3">Posts per year</h2>
    <div class="space-y-2">
      {% for yr in years %}
      {% set count = byYear[yr] %}
      {% set pct = ((count / maxPerYear) * 100) | round %}
      <div class="flex items-center gap-3">
        <span class="meta-text text-xs text-gray-400 dark:text-gray-500 w-10 shrink-0 text-right">{{ yr }}</span>
        <div class="flex-1 h-5 bg-gray-100 dark:bg-gray-800 rounded overflow-hidden">
          <div class="h-full rounded" style="width: {{ pct }}%; background: color-mix(in srgb, var(--accent-color) 75%, transparent);"></div>
        </div>
        <span class="meta-text text-xs text-gray-500 dark:text-gray-400 w-5 shrink-0 text-right">{{ count }}</span>
      </div>
      {% endfor %}
    </div>
  </div>

</div>

{# ── Lighthouse ── #}
<div class="not-prose mb-8">
  <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-3">Lighthouse</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8">
    <div class="flex items-center gap-3 py-2.5 border-b border-gray-100 dark:border-gray-800/80">
      <span class="text-sm text-gray-600 dark:text-gray-400 w-28 shrink-0">Performance</span>
      <div class="flex-1 h-2 bg-gray-100 dark:bg-gray-800 rounded-full overflow-hidden">
        <div class="h-full rounded-full bg-emerald-500" style="width: {{ lighthouse.metrics.performance | default(0) }}%"></div>
      </div>
      <span class="meta-text text-sm font-semibold text-gray-900 dark:text-gray-100 w-8 text-right">{{ lighthouse.metrics.performance | default(0) }}</span>
    </div>
    <div class="flex items-center gap-3 py-2.5 border-b border-gray-100 dark:border-gray-800/80">
      <span class="text-sm text-gray-600 dark:text-gray-400 w-28 shrink-0">Accessibility</span>
      <div class="flex-1 h-2 bg-gray-100 dark:bg-gray-800 rounded-full overflow-hidden">
        <div class="h-full rounded-full bg-blue-500" style="width: {{ lighthouse.metrics.accessibility | default(0) }}%"></div>
      </div>
      <span class="meta-text text-sm font-semibold text-gray-900 dark:text-gray-100 w-8 text-right">{{ lighthouse.metrics.accessibility | default(0) }}</span>
    </div>
    <div class="flex items-center gap-3 py-2.5 border-b border-gray-100 dark:border-gray-800/80 sm:border-b-0">
      <span class="text-sm text-gray-600 dark:text-gray-400 w-28 shrink-0">Best Practices</span>
      <div class="flex-1 h-2 bg-gray-100 dark:bg-gray-800 rounded-full overflow-hidden">
        <div class="h-full rounded-full bg-purple-500" style="width: {{ lighthouse.metrics.bestPractices | default(0) }}%"></div>
      </div>
      <span class="meta-text text-sm font-semibold text-gray-900 dark:text-gray-100 w-8 text-right">{{ lighthouse.metrics.bestPractices | default(0) }}</span>
    </div>
    <div class="flex items-center gap-3 py-2.5">
      <span class="text-sm text-gray-600 dark:text-gray-400 w-28 shrink-0">SEO</span>
      <div class="flex-1 h-2 bg-gray-100 dark:bg-gray-800 rounded-full overflow-hidden">
        <div class="h-full rounded-full bg-amber-500" style="width: {{ lighthouse.metrics.seo | default(0) }}%"></div>
      </div>
      <span class="meta-text text-sm font-semibold text-gray-900 dark:text-gray-100 w-8 text-right">{{ lighthouse.metrics.seo | default(0) }}</span>
    </div>
  </div>
  {% if lighthouse.updatedAt %}
  <p class="text-xs text-gray-400 dark:text-gray-600 mt-2">{{ lighthouse.updatedAt }} · {{ lighthouse.source }}</p>
  {% endif %}
</div>

{# ── Top tags ── #}
<div class="not-prose mb-8">
  <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-3">Top Tags</h2>
  <div class="flex flex-wrap gap-1.5">
    {% for tag in collections.tagList | head(20) %}
      {% set tagCount = collections[tag].length %}
      {% set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
      <a href="{{ tagUrl | url }}" class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded text-xs bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" style="text-decoration:none;">
        {{ tag }}<span class="opacity-50">{{ tagCount }}</span>
      </a>
    {% endfor %}
  </div>
</div>

{# ── Stack ── #}
<div class="not-prose">
  <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-3">Stack</h2>
  <div class="divide-y divide-gray-100 dark:divide-gray-800/80">
    <div class="py-2 flex justify-between"><span class="text-sm text-gray-500 dark:text-gray-400">Generator</span><span class="meta-text text-sm text-gray-700 dark:text-gray-300">{{ eleventy.generator }}</span></div>
    <div class="py-2 flex justify-between"><span class="text-sm text-gray-500 dark:text-gray-400">CSS</span><span class="meta-text text-sm text-gray-700 dark:text-gray-300">Tailwind CSS v4</span></div>
    <div class="py-2 flex justify-between"><span class="text-sm text-gray-500 dark:text-gray-400">JS</span><span class="meta-text text-sm text-gray-700 dark:text-gray-300">Alpine.js</span></div>
    <div class="py-2 flex justify-between"><span class="text-sm text-gray-500 dark:text-gray-400">Hosting</span><span class="meta-text text-sm text-gray-700 dark:text-gray-300">Netlify</span></div>
    <div class="py-2 flex justify-between"><span class="text-sm text-gray-500 dark:text-gray-400">Comments</span><span class="meta-text text-sm text-gray-700 dark:text-gray-300">Giscus</span></div>
    <div class="py-2 flex justify-between"><span class="text-sm text-gray-500 dark:text-gray-400">Analytics</span><span class="meta-text text-sm text-gray-700 dark:text-gray-300">None (privacy-first)</span></div>
  </div>
</div>
