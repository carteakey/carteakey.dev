---
layout: layouts/base.njk
title: Stats
description: Numbers and insights about this site.
eleventyNavigation:
  key: Stats
  order: 9
permalink: /stats/
---

{% include "components/breadcrumbs.njk" %}

{% set pageTitle = "Stats" %}
{% set pageDescription = "Numbers. Updated every build." %}
{% include "components/page-header.njk" %}

{# ── Compute stats using filters ── #}
{% set totalWords = collections.posts | sumWordCounts %}
{% set avgWords = 0 %}
{% if collections.posts.length > 0 %}
  {% set avgWords = (totalWords / collections.posts.length) | round %}
{% endif %}
{% set byYear = collections.posts | countByYear %}
{% set years = byYear | keys | sort | reverse %}
{% set maxPerYear = 1 %}
{% for yr in years %}
  {% if byYear[yr] > maxPerYear %}{% set maxPerYear = byYear[yr] %}{% endif %}
{% endfor %}

{% set currentYear = "now" | date("Y") %}
{% set currentMonth = "now" | date("n") %}
{% set postsThisYear = byYear[currentYear] | default(0) %}
{% set postsThisMonth = collections.posts | countInYearMonth(currentYear, currentMonth) %}

{% set totalUpvotes = 0 %}
{% for slug, count in upvotes.posts %}
  {% set totalUpvotes = totalUpvotes + count %}
{% endfor %}

{# ── Hero numbers ── #}
<div class="not-prose grid grid-cols-2 sm:grid-cols-4 divide-x divide-y sm:divide-y-0 divide-gray-200 dark:divide-gray-800 surface rounded-sm overflow-hidden mb-12">
  <div class="p-6 text-center">
    <div class="font-display text-3xl sm:text-4xl font-bold" style="color: var(--accent-color)">{{ collections.posts.length }}</div>
    <div class="meta-text text-[0.65rem] mt-2">Posts</div>
  </div>
  <div class="p-6 text-center">
    <div class="font-display text-3xl sm:text-4xl font-bold" style="color: var(--accent-color)">{{ collections.snippets.length }}</div>
    <div class="meta-text text-[0.65rem] mt-2">Snippets</div>
  </div>
  <div class="p-6 text-center">
    <div class="font-display text-3xl sm:text-4xl font-bold" style="color: var(--accent-color)">
      {% if totalWords > 1000 %}{{ (totalWords / 1000) | round(1) }}k{% else %}{{ totalWords }}{% endif %}
    </div>
    <div class="meta-text text-[0.65rem] mt-2">Words</div>
  </div>
  <div class="p-6 text-center">
    <div class="font-display text-3xl sm:text-4xl font-bold" style="color: var(--accent-color)">{{ totalUpvotes }}</div>
    <div class="meta-text text-[0.65rem] mt-2">Upvotes</div>
  </div>
</div>

{# ── Two-column: writing rows | posts-per-year bars ── #}
<div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-12 mb-12">

  <div>
    <h2 class="editorial-kicker mb-4">Writing</h2>
    <div class="divide-y divide-gray-100 dark:divide-gray-800/80">

      <div class="py-2.5 flex items-baseline justify-between">
        <span class="editorial-support">Total words</span>
        <span class="editorial-title-compact">{{ totalWords | numberString }}</span>
      </div>

      <div class="py-2.5 flex items-baseline justify-between">
        <span class="editorial-support">Avg words / post</span>
        <span class="editorial-title-compact">{{ avgWords | numberString }}</span>
      </div>

      <div class="py-2.5 flex items-baseline justify-between">
        <span class="editorial-support">Posts this year</span>
        <span class="editorial-title-compact">{{ postsThisYear }}</span>
      </div>

      <div class="py-2.5 flex items-baseline justify-between">
        <span class="editorial-support">Posts this month</span>
        <span class="editorial-title-compact">{{ postsThisMonth }}</span>
      </div>

      {% set latestPost = collections.posts | sortByDate | first %}
      {% if latestPost %}
      <div class="py-2.5 flex items-baseline justify-between gap-4">
        <span class="editorial-support shrink-0">Latest</span>
        <a href="{{ latestPost.url }}" class="editorial-title-link-compact text-right truncate min-w-0" style="text-decoration:none;">{{ latestPost.data.title }}</a>
      </div>
      {% endif %}

      <div class="py-2.5 flex items-baseline justify-between">
        <span class="editorial-support">Post tags</span>
        <span class="editorial-title-compact">{{ collections.tagList.length }}</span>
      </div>

      <div class="py-2.5 flex items-baseline justify-between">
        <span class="editorial-support">Snippet languages</span>
        <span class="editorial-title-compact">{{ collections.snippets | map('data.language') | uniq | length }}</span>
      </div>

      <div class="py-2.5 flex items-baseline justify-between">
        <span class="editorial-support">Total pages</span>
        <span class="editorial-title-compact">{{ collections.all.length }}</span>
      </div>

      <div class="py-2.5 flex items-baseline justify-between">
        <span class="editorial-support">Last build</span>
        <span class="meta-text">{{ page.date | readableDate }} · {{ page.date | date('h:mm a') }}</span>
      </div>

    </div>
  </div>

  {# Posts per year bar chart #}
  <div>
    <h2 class="editorial-kicker mb-4">Posts per year</h2>
    <div class="space-y-3">
      {% for yr in years %}
      {% set count = byYear[yr] %}
      {% set pct = ((count / maxPerYear) * 100) | round %}
      <div class="flex items-center gap-3">
        <span class="meta-text w-10 shrink-0 text-right">{{ yr }}</span>
        <div class="flex-1 h-5 bg-gray-100 dark:bg-gray-800 rounded-sm overflow-hidden">
          <div class="h-full rounded-sm" style="width: {{ pct }}%; background: color-mix(in srgb, var(--accent-color) 75%, transparent);"></div>
        </div>
        <span class="meta-text w-5 shrink-0 text-right">{{ count }}</span>
      </div>
      {% endfor %}
    </div>
  </div>

</div>

{# ── Lighthouse ── #}
<div class="not-prose mb-12">
  <h2 class="editorial-kicker mb-4">Lighthouse</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8">
    <div class="flex items-center gap-3 py-2.5 border-b border-gray-100 dark:border-gray-800/80">
      <span class="editorial-support w-28 shrink-0">Performance</span>
      <div class="flex-1 h-2 bg-gray-100 dark:bg-gray-800 rounded-sm overflow-hidden">
        <div class="h-full rounded-sm bg-emerald-500" style="width: {{ lighthouse.metrics.performance | default(0) }}%"></div>
      </div>
      <span class="editorial-title-compact w-8 text-right">{{ lighthouse.metrics.performance | default(0) }}</span>
    </div>
    <div class="flex items-center gap-3 py-2.5 border-b border-gray-100 dark:border-gray-800/80">
      <span class="editorial-support w-28 shrink-0">Accessibility</span>
      <div class="flex-1 h-2 bg-gray-100 dark:bg-gray-800 rounded-sm overflow-hidden">
        <div class="h-full rounded-sm bg-blue-500" style="width: {{ lighthouse.metrics.accessibility | default(0) }}%"></div>
      </div>
      <span class="editorial-title-compact w-8 text-right">{{ lighthouse.metrics.accessibility | default(0) }}</span>
    </div>
    <div class="flex items-center gap-3 py-2.5 border-b border-gray-100 dark:border-gray-800/80 sm:border-b-0">
      <span class="editorial-support w-28 shrink-0">Best Practices</span>
      <div class="flex-1 h-2 bg-gray-100 dark:bg-gray-800 rounded-sm overflow-hidden">
        <div class="h-full rounded-sm bg-purple-500" style="width: {{ lighthouse.metrics.bestPractices | default(0) }}%"></div>
      </div>
      <span class="editorial-title-compact w-8 text-right">{{ lighthouse.metrics.bestPractices | default(0) }}</span>
    </div>
    <div class="flex items-center gap-3 py-2.5">
      <span class="editorial-support w-28 shrink-0">SEO</span>
      <div class="flex-1 h-2 bg-gray-100 dark:bg-gray-800 rounded-sm overflow-hidden">
        <div class="h-full rounded-sm bg-amber-500" style="width: {{ lighthouse.metrics.seo | default(0) }}%"></div>
      </div>
      <span class="editorial-title-compact w-8 text-right">{{ lighthouse.metrics.seo | default(0) }}</span>
    </div>
  </div>
  {% if lighthouse.updatedAt %}
  <p class="editorial-support-compact mt-3">{{ lighthouse.updatedAt }} · {{ lighthouse.source }}</p>
  {% endif %}
</div>

{# ── Top tags ── #}
<div class="not-prose mb-12">
  <h2 class="editorial-kicker mb-4">Top Tags</h2>
  <div class="flex flex-wrap gap-1.5">
    {% for tag in collections.tagList | head(20) %}
      {% set tagCount = collections[tag].length %}
      {% set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
      <a href="{{ tagUrl | url }}" class="badge badge-tag" style="text-decoration:none;">
        {{ tag }}<span class="opacity-50 ml-1">{{ tagCount }}</span>
      </a>
    {% endfor %}
  </div>
</div>

{# ── Stack ── #}
<div class="not-prose mb-8">
  <h2 class="editorial-kicker mb-4">Stack</h2>
  <div class="divide-y divide-gray-100 dark:divide-gray-800/80">
    <div class="py-2.5 flex justify-between"><span class="editorial-support">Generator</span><span class="meta-text">{{ eleventy.generator }}</span></div>
    <div class="py-2.5 flex justify-between"><span class="editorial-support">CSS</span><span class="meta-text">Tailwind CSS v4</span></div>
    <div class="py-2.5 flex justify-between"><span class="editorial-support">JS</span><span class="meta-text">Alpine.js</span></div>
    <div class="py-2.5 flex justify-between"><span class="editorial-support">Hosting</span><span class="meta-text">Netlify</span></div>
    <div class="py-2.5 flex justify-between"><span class="editorial-support">Comments</span><span class="meta-text">Giscus</span></div>
    <div class="py-2.5 flex justify-between"><span class="editorial-support">Analytics</span><span class="meta-text">None (privacy-first)</span></div>
  </div>
</div>
