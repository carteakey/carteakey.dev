---
layout: layouts/base.njk
title: Snippets
description: A collection of useful code snippets and quick tips
eleventyNavigation:
  key: Snippets
  order: 3
---

{% include "components/breadcrumbs.njk" %}

<div class="flex items-baseline justify-between mb-2">
  <div class="flex items-baseline gap-3">
    <h1 class="text-2xl font-semibold tracking-tight m-0">Snippets</h1>
    <span class="meta-text text-xs text-gray-400 dark:text-gray-500">{{ collections.snippets | length }} snippets</span>
  </div>
  <div class="flex items-center gap-2">
    <div class="relative">
      {% feather "search", class="w-3.5 h-3.5 text-gray-400 absolute left-2.5 top-1/2 -translate-y-1/2 pointer-events-none" %}
      <input
        type="text"
        id="snippetSearch"
        placeholder="Search..."
        class="rounded-md border border-gray-200 dark:border-gray-700 bg-transparent py-1.5 pl-8 pr-3 text-sm accent-field focus:outline-none dark:text-gray-100 w-40 placeholder:text-gray-400"
      >
    </div>
    <div class="view-toggle" x-data="{ viewMode: 'list' }">
      <button type="button" title="List view" :class="{ 'active': viewMode === 'list' }" @click="viewMode = 'list'; document.getElementById('snippetGrid').classList.add('hidden'); document.getElementById('snippetList').classList.remove('hidden');">
        {% feather "list", class="w-4 h-4" %}
      </button>
      <button type="button" title="Grid view" :class="{ 'active': viewMode === 'grid' }" @click="viewMode = 'grid'; document.getElementById('snippetList').classList.add('hidden'); document.getElementById('snippetGrid').classList.remove('hidden');">
        {% feather "grid", class="w-4 h-4" %}
      </button>
    </div>
  </div>
</div>

{# ── LIST VIEW (default) ─────────────────────────────── #}
<div id="snippetList" class="mt-4 divide-y divide-gray-100 dark:divide-gray-800/80">
  {%- for snippet in collections.snippets -%}
    {% set rawTags = snippet.data.tags | default([]) %}
    {% set filteredTags = rawTags | filterTagList %}
    {% set searchExcerpt = snippet.templateContent | striptags | replace('\n', ' ') | truncate(160, true, '') | lower %}
    <article
      class="py-3.5 group"
      data-snippet-card
      data-title="{{ snippet.data.title | lower }}"
      data-tags="{{ filteredTags | join(' ') | lower }}"
      data-language="{{ snippet.data.language | default('') | lower }}"
      data-body="{{ searchExcerpt }}"
    >
      <div class="flex flex-col md:flex-row md:gap-6">
        <div class="shrink-0 md:w-36 flex flex-col gap-1 pt-0.5">
          <time class="meta-text text-xs text-gray-400 dark:text-gray-500" datetime="{{ snippet.date | htmlDateString }}">{{ snippet.date | readableDate }}</time>
          {% if snippet.data.language %}
            <span class="hidden md:inline-flex meta-text text-[0.62rem] px-1.5 py-0.5 rounded bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 w-fit">{{ snippet.data.language }}</span>
          {% endif %}
        </div>
        <div class="flex-1 min-w-0">
          <div class="leading-snug">
            <a href="{{ snippet.url }}" class="font-semibold text-gray-900 dark:text-gray-100 title-hover" style="text-decoration: none;">{{ snippet.data.title }}</a>
          </div>
          {% if snippet.data.description %}
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5 m-0 leading-relaxed">{{ snippet.data.description }}</p>
          {% endif %}
          <div class="md:hidden flex flex-wrap items-center gap-x-2 gap-y-1 mt-1.5">
            <span class="meta-text text-[0.65rem] text-gray-400 dark:text-gray-500">{{ snippet.date | readableDate }}</span>
            {% if snippet.data.language %}
              <span class="meta-text text-[0.62rem] px-1 py-0.5 rounded bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400">{{ snippet.data.language }}</span>
            {% endif %}
          </div>
        </div>
      </div>
    </article>
  {%- endfor -%}
</div>

{# ── GRID VIEW ───────────────────────────────────────── #}
<div id="snippetGrid" class="hidden mt-4 grid gap-3 md:grid-cols-2 lg:grid-cols-3 items-start">
  {%- for snippet in collections.snippets -%}
    {% set rawTags = snippet.data.tags | default([]) %}
    {% set filteredTags = rawTags | filterTagList %}
    {% set excerpt = snippet.templateContent | striptags | replace('\n', ' ') | truncate(100, true, '…') %}
    {% set searchExcerpt = snippet.templateContent | striptags | replace('\n', ' ') | truncate(160, true, '') | lower %}
    <article
      class="feed-card-full"
      data-snippet-card
      data-title="{{ snippet.data.title | lower }}"
      data-tags="{{ filteredTags | join(' ') | lower }}"
      data-language="{{ snippet.data.language | default('') | lower }}"
      data-body="{{ searchExcerpt }}"
    >
      <div class="flex items-center gap-2 mb-2">
        <span class="feed-list-dot bg-purple-400 shrink-0"></span>
        <time class="meta-text text-[0.68rem] text-gray-400 dark:text-gray-500">{{ snippet.date | readableDate }}</time>
        {% if snippet.data.language %}
          <span class="meta-text text-[0.62rem] px-1.5 py-0.5 rounded bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 ml-auto">{{ snippet.data.language }}</span>
        {% endif %}
      </div>
      <h3 class="text-sm font-semibold leading-snug text-gray-900 dark:text-gray-100 m-0">
        <a href="{{ snippet.url }}" class="title-hover" style="color: inherit; text-decoration: none;">{{ snippet.data.title }}</a>
      </h3>
      {% if excerpt %}
        <p class="text-xs leading-relaxed text-gray-500 dark:text-gray-400 mt-1.5 m-0 line-clamp-2">{{ excerpt }}</p>
      {% endif %}
      {% if filteredTags | length %}
        <div class="flex flex-wrap gap-1 mt-2.5">
          {% for tag in filteredTags | head(3) %}
            <a href="/snippets/tags/{{ tag | slugify }}/" class="text-[0.6rem] px-1.5 py-0.5 rounded bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 title-hover" style="text-decoration: none;">#{{ tag }}</a>
          {% endfor %}
        </div>
      {% endif %}
    </article>
  {%- endfor -%}
</div>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  const searchInput = document.getElementById('snippetSearch');
  const snippetCards = Array.from(document.querySelectorAll('[data-snippet-card]'));

  searchInput.addEventListener('input', (e) => {
    const term = e.target.value.trim().toLowerCase();
    snippetCards.forEach((card) => {
      const matches = !term || ['title','tags','language','body'].some(k => (card.dataset[k] || '').includes(term));
      card.closest('article').classList.toggle('hidden', !matches);
    });
  });
</script>

