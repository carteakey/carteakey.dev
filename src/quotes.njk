---
layout: layouts/base.njk
title: Quotes
permalink: /quotes/
fullWidth: true
eleventyNavigation:
  key: Quotes
  order: 7
---

<div class="max-w-[1400px] mx-auto space-y-10">
    <div class="max-w-3xl mx-auto">
        {% include "components/breadcrumbs.njk" %}

        {% set pageTitle = "Quotes" %}
        {% set pageDescription = "Words that stick with me-updated whenever I stumble upon lines worth rereading." %}
        {% include "components/page-header.njk" %}
    </div>

    <!-- Quote of the Day Section -->
    <section class="surface surface-padding rounded-sm not-prose max-w-3xl mx-auto">
        <div class="flex flex-col gap-3">
            <div class="flex items-center gap-2 meta-text text-sm" style="color: var(--accent-color);">
                {% feather "zap", class="w-4 h-4" %}
                Quote of the Day
            </div>
            <blockquote id="qotd" class="editorial-title text-sm leading-relaxed m-0">
                {{ qotd.quote }}
            </blockquote>
            <p class="text-right editorial-support-compact italic mt-2 m-0" id="who">
                Powered by {{ qotd.provider }}
            </p>
        </div>
    </section>

    <!-- Static Quotes Section -->
    <section class="not-prose">
        <h2 class="editorial-kicker mb-6">Saved Lines</h2>
        <div
          class="grid gap-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 items-start feed-masonry"
          data-feed-masonry
          style="--feed-row-height: 16px;"
        >
            {% for quote in quotes %}
            <article class="feed-card surface surface-compact surface-hover rounded-sm">
                <blockquote class="m-0">
                    <p class="editorial-support-compact italic m-0">"{{ quote.quote | replace('\n', '<br>') | safe }}"</p>
                    <cite class="block meta-text text-[0.65rem] mt-3">- {{ quote.author }}</cite>
                </blockquote>
            </article>
            {% endfor %}
        </div>
    </section>
</div>

{% include "components/feed-masonry-script.njk" %}

<!-- The script itself, loaded AFTER your root element. -->
<script src="/static/js/typeit.min.js"></script>
<script>
    const instance = new TypeIt("#qotd", {
        speed: 30,
        waitUntilVisible: true
    })
    instance.go();
</script>
