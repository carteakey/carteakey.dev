---
layout: layouts/base.njk
title: Notes
description: Short notes, observations, and micro posts.
permalink: /notes/
eleventyNavigation:
  key: Notes
  order: 6
---

{% include "components/breadcrumbs.njk" %}

<div class="flex items-baseline justify-between mb-2">
  <div class="flex items-baseline gap-3">
    <h1 class="text-2xl font-semibold tracking-tight m-0">Notes</h1>
    <span class="meta-text text-xs text-gray-400 dark:text-gray-500">{{ collections.notes | length }} notes</span>
  </div>
</div>

<p class="text-sm text-gray-500 dark:text-gray-400 mt-0 mb-4">Short observations, micro posts, and things that don't warrant a full blog post.</p>

<div class="divide-y divide-gray-100 dark:divide-gray-800/80">
  {%- for note in collections.notes | reverse -%}
  <article class="py-3.5 group">
    <div class="flex flex-col md:flex-row md:gap-6">
      <div class="shrink-0 md:w-28 pt-0.5">
        <time class="meta-text text-xs text-gray-400 dark:text-gray-500" datetime="{{ note.date | htmlDateString }}">{{ note.date | readableDate }}</time>
      </div>
      <div class="flex-1 min-w-0">
        {% if note.data.title %}
          <div class="leading-snug mb-1">
            <a href="{{ note.url }}" class="font-semibold text-gray-900 dark:text-gray-100 title-hover" style="text-decoration: none;">{{ note.data.title }}</a>
          </div>
        {% endif %}
        <div class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed site-content prose-sm">
          {{ note.templateContent | safe }}
        </div>
        <div class="mt-1.5">
          <a href="{{ note.url }}" class="text-xs text-gray-400 dark:text-gray-500 hover:underline" style="text-decoration:none;">Permalink →</a>
        </div>
      </div>
    </div>
  </article>
  {%- endfor -%}
</div>
