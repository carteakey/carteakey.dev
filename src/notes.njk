layout: layouts/base.njk
title: Notes
description: Short notes, observations, and micro posts.
permalink: /notes/
eleventyNavigation:
  key: Notes
  order: 6
---

{% include "components/breadcrumbs.njk" %}

{% set pageEyebrow = "Short-form" %}
{% set pageTitle = "Notes" %}
{% set pageDescription = "Short observations, micro posts, and things that do not need a full blog post." %}
{% set itemCount = collections.notes | length %}
{% set itemLabel = "notes" %}
{% include "components/page-header.njk" %}

<div class="notes-index divide-y divide-gray-100 dark:divide-gray-800/80">
  {%- for note in collections.notes -%}
  <article class="note-index-row group">
    <div class="flex flex-col md:flex-row md:gap-6">
      <div class="shrink-0 md:w-28 pt-0.5">
        <time class="note-index-date meta-text" datetime="{{ note.date | htmlDateString }}">{{ note.date | readableDate }}</time>
      </div>
      <div class="flex-1 min-w-0">
        {% if note.data.title %}
          <div class="leading-snug mb-1">
            <a href="{{ note.url }}" class="note-index-title title-hover">{{ note.data.title }}</a>
          </div>
        {% endif %}
        <div class="note-index-body site-content">
          {{ note.templateContent | safe }}
        </div>
        <div class="mt-1.5">
          <a href="{{ note.url }}" class="note-index-link">Permalink →</a>
        </div>
      </div>
    </div>
  </article>
  {%- endfor -%}
</div>
