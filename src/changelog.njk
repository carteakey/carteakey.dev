---
layout: layouts/base.njk
title: Changelog
description: A history of changes and new features on this site.
permalink: /changelog/
eleventyNavigation:
  key: Changelog
  order: 9
---

{% include "components/breadcrumbs.njk" %}

<div class="not-prose mb-6 flex items-baseline justify-between">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight m-0">Changelog</h1>
    <p class="text-sm text-gray-400 dark:text-gray-500 mt-1">A running history of site changes.</p>
  </div>
  <a href="https://github.com/carteakey/carteakey.dev/blob/main/docs/CHANGELOG.md" target="_blank" rel="noopener" class="text-xs text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" style="text-decoration:none;">Raw ↗</a>
</div>

<div class="not-prose relative">
  {# vertical timeline line #}
  <div class="absolute left-[0.4rem] top-2 bottom-2 w-px bg-gray-200 dark:bg-gray-800"></div>

  <ul class="list-none m-0 p-0 space-y-8 pl-7">
    {% for entry in changelog %}
    <li class="relative">
      {# timeline dot #}
      <div class="absolute -left-7 top-1.5 w-3 h-3 rounded-full border-2 border-white dark:border-zinc-950" style="background: var(--accent-color);"></div>

      <div class="flex flex-wrap items-baseline gap-3 mb-2">
        <span class="font-mono font-semibold text-sm text-gray-900 dark:text-gray-100" style="color: var(--accent-color);">v{{ entry.version }}</span>
        {% if entry.date %}
          <time class="meta-text text-xs text-gray-400 dark:text-gray-500">{{ entry.date }}</time>
        {% endif %}
      </div>

      <div class="space-y-2">
        {% if entry.sections.Added %}
        <div>
          <span class="meta-text text-[0.65rem] font-semibold uppercase tracking-wider text-emerald-500 dark:text-emerald-400 mr-2">Added</span>
          <ul class="mt-1 space-y-0.5 list-none m-0 p-0">
            {% for item in entry.sections.Added %}
            <li class="text-sm text-gray-700 dark:text-gray-300 flex gap-2">
              <span class="text-emerald-400 shrink-0 mt-0.5">+</span>
              <span>{{ item }}</span>
            </li>
            {% endfor %}
          </ul>
        </div>
        {% endif %}

        {% if entry.sections.Changed %}
        <div>
          <span class="meta-text text-[0.65rem] font-semibold uppercase tracking-wider text-blue-500 dark:text-blue-400 mr-2">Changed</span>
          <ul class="mt-1 space-y-0.5 list-none m-0 p-0">
            {% for item in entry.sections.Changed %}
            <li class="text-sm text-gray-700 dark:text-gray-300 flex gap-2">
              <span class="text-blue-400 shrink-0 mt-0.5">~</span>
              <span>{{ item }}</span>
            </li>
            {% endfor %}
          </ul>
        </div>
        {% endif %}

        {% if entry.sections.Fixed %}
        <div>
          <span class="meta-text text-[0.65rem] font-semibold uppercase tracking-wider text-amber-500 dark:text-amber-400 mr-2">Fixed</span>
          <ul class="mt-1 space-y-0.5 list-none m-0 p-0">
            {% for item in entry.sections.Fixed %}
            <li class="text-sm text-gray-700 dark:text-gray-300 flex gap-2">
              <span class="text-amber-400 shrink-0 mt-0.5">⚑</span>
              <span>{{ item }}</span>
            </li>
            {% endfor %}
          </ul>
        </div>
        {% endif %}

        {% if entry.sections.Removed %}
        <div>
          <span class="meta-text text-[0.65rem] font-semibold uppercase tracking-wider text-red-500 dark:text-red-400 mr-2">Removed</span>
          <ul class="mt-1 space-y-0.5 list-none m-0 p-0">
            {% for item in entry.sections.Removed %}
            <li class="text-sm text-gray-700 dark:text-gray-300 flex gap-2">
              <span class="text-red-400 shrink-0 mt-0.5">−</span>
              <span>{{ item }}</span>
            </li>
            {% endfor %}
          </ul>
        </div>
        {% endif %}
      </div>
    </li>
    {% endfor %}
  </ul>
</div>
