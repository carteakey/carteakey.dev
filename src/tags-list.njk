---
permalink: /tags/
layout: layouts/home.njk
---

<h1>Tags</h1>

<ul class="space-y-2">
{% set sortedTags = collections.tagList | sortTagsByCount(collections) %}
{% for tagItem in sortedTags %}
  {% set tagUrl %}/tags/{{ tagItem.name | slugify }}/{% endset %}
  <li class="flex items-center justify-between">
    <a href="{{ tagUrl | url }}" class="post-tag accent-link">{{ tagItem.name }}</a>
    <span class="editorial-support-compact ml-2">({{ tagItem.count }})</span>
  </li>
{% endfor %}
</ul>