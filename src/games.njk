---
layout: layouts/base.njk
title: Games
---

{% set pageTitle = title %}
{% set pageDescription = "Here are my recently played games from Steam" %}

{% include "components/breadcrumbs.njk" %}

<h1 class="text-2xl font-semibold tracking-tight m-0">Recent Games</h1>
<p class="text-sm text-gray-500 dark:text-gray-400 mt-1 mb-6">{{ pageDescription }}</p>

<div class="not-prose grid gap-3 md:grid-cols-3">
    {% for game in steam | head(8) %}
    <article class="card card-hover overflow-hidden p-0">
        <img src="{{ game.library_hero }}" alt="{{ game.name }} hero" loading="lazy" decoding="async" class="h-36 w-full object-cover">
        
        <div class="flex flex-col items-center gap-1 p-3 text-center">
            <a href="{{ game.url }}" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-gray-900 dark:text-gray-100 accent-link" style="text-decoration:none;">
                {{ game.name }}
            </a>
            <p class="meta-text text-[0.65rem] text-gray-400 dark:text-gray-500">
                {% if game.playtime_2weeks > 0 %}{{ game.playtime_2weeks }}h last 2 weeks{% endif %}
                {% if game.playtime_forever > 0 %}{% if game.playtime_2weeks > 0 %} · {% endif %}{{ game.playtime_forever }}h total{% endif %}
            </p>
        </div>
    </article>
    {% endfor %}
</div>
