---
layout: layouts/base.njk
title: Bookmarks
description: A curated list of articles, tools, and resources I recommend
eleventyNavigation:
  key: Bookmarks
  order: 10
permalink: /bookmarks/
---

{% include "components/breadcrumbs.njk" %}

{% set totalCount = bookmarks.bookmarks | length %}
{% set categories = bookmarks.bookmarks | map('category') | uniq | sort %}
{% set sortedDates = bookmarks.bookmarks | map('date') | sort %}
{% set lastUpdated = (sortedDates | reverse)[0] %}

{% set pageTitle = title %}
{% set pageDescription = "Essays, tools, talks, and rabbit holes I keep coming back to." %}
{% set itemCount = totalCount %}
{% set itemLabel = "bookmarks" %}

<div class="max-w-5xl mx-auto">
  {% include "components/page-header.njk" %}

  <div class="mt-2 flex flex-wrap items-center gap-3 meta-text text-xs">
    <span>Updated {{ lastUpdated | readableDate }}</span>
    <span>·</span>
    <div class="flex flex-wrap gap-1">
      {% for category in categories %}
        <a href="#{{ category | slugify }}" class="badge badge-tag badge-compact" style="text-decoration:none;">{{ category }}</a>
      {% endfor %}
    </div>
  </div>

  {% for category in categories %}
    {% set items = bookmarks.bookmarks | selectattr('category', 'equalto', category) | sort(attribute='date') | reverse %}
    {% set catCount = items | length %}
    <section id="{{ category | slugify }}" class="mt-10">
      <h2 class="editorial-kicker flex items-center gap-2 mb-4">
        {{ category }}
        <span class="opacity-50 ml-1">{{ catCount }}</span>
      </h2>

      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {% for bookmark in items %}
          {% set domain = bookmark.url | domainFromUrl %}
          {% set favicon = bookmark.url | faviconUrl %}
          {% set domainInitial = bookmark.url | domainInitial %}
          <article class="surface surface-compact surface-hover rounded-sm flex flex-col h-full justify-between">
            <div>
              <a href="{{ bookmark.url }}" target="_blank" rel="noopener noreferrer" class="editorial-title-link-compact line-clamp-1" style="text-decoration:none;">
                  {{ bookmark.title }}
                </a>
              {% if bookmark.description %}
                <p class="mt-1.5 editorial-support-compact line-clamp-2 m-0">{{ bookmark.description }}</p>
              {% endif %}
            </div>
            {% if domain %}
              <p class="meta-text text-[0.65rem] mt-3 m-0">{{ domain }}</p>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    </section>
  {% endfor %}

  <div class="mt-12 surface surface-padding rounded-sm">
    <p class="editorial-support m-0">
      Have a suggestion? <a href="mailto:{{ metadata.author.email }}" class="editorial-meta-link">Drop me a note</a>.
    </p>
  </div>
</div>

<style>
  .line-clamp-1 { display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>
