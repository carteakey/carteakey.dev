---
layout: layouts/home.njk
htmlTemplateEngine: "webc"
---
{% from "components/feed-card.njk" import feedCard %}

{# ── HERO ─────────────────────────────────────────────── #}
<div class="flex flex-col sm:flex-row gap-5 items-start not-prose animate-enter py-2">
  <div class="relative shrink-0 mt-0.5">
    <div class="absolute -inset-1 rounded-full opacity-70" style="background: conic-gradient(from 180deg, var(--accent-color), #7c3aed, #0ea5e9, var(--accent-color));"></div>
    <div class="relative z-10 w-20 h-20 rounded-full overflow-hidden">
      {% image "./src/static/img/headshot.png" , "me", "w-full h-full object-cover" %}
    </div>
  </div>
  <div class="space-y-2">
    <p class="text-base font-semibold text-gray-900 dark:text-gray-100 m-0">
      Hi 👋🏼, I'm <span style="color: var(--accent-color); font-weight: 700;">Kartikey</span> — welcome to my corner of the internet!
    </p>
    <p class="text-sm text-gray-600 dark:text-gray-400 m-0 leading-relaxed">
      I'm a data analyst from Toronto. Outside work I tinker with tech and build <a href="/portfolio" class="accent-link font-semibold" style="text-decoration: none;">side projects</a>.
      Here I write about linux, AI, data science, and whatever else catches my eye — grab a coffee and look around.
    </p>
    <div class="flex flex-wrap gap-x-3 gap-y-1 pt-0.5 text-xs text-gray-400 dark:text-gray-500">
      <a href="/about" class="hover:text-gray-700 dark:hover:text-gray-300 transition-colors" style="text-decoration: none;">About</a>
      <span>·</span>
      <a href="/now" class="hover:text-gray-700 dark:hover:text-gray-300 transition-colors" style="text-decoration: none;">Now</a>
      <span>·</span>
      <a href="/cv" class="hover:text-gray-700 dark:hover:text-gray-300 transition-colors" style="text-decoration: none;">CV</a>
      <span>·</span>
      <a href="https://github.com/carteakey" class="hover:text-gray-700 dark:hover:text-gray-300 transition-colors" style="text-decoration: none;" target="_blank" rel="noopener">GitHub ↗</a>
    </div>
  </div>
</div>

<hr class="my-5 border-gray-200 dark:border-gray-800" />

{# ── FEATURED POST ─────────────────────────────────────── #}
{% set highlightedPost = collections.featuredPost %}
{% if highlightedPost %}
  <div class="not-prose animate-enter stagger-1 mb-5">
    <div class="mb-2">
      <span class="meta-text text-[0.65rem] uppercase tracking-wider font-semibold" style="color: var(--accent-color);">★ Featured</span>
    </div>
    <a href="{{ highlightedPost.url }}" class="block group" style="text-decoration: none;">
      <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100 leading-snug m-0 transition-colors" style="transition: color 0.15s;">
        <span class="group-hover:underline" style="text-decoration-color: var(--accent-color);">{{ highlightedPost.data.title }}</span>
      </h2>
      {% if highlightedPost.data.description %}
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1 m-0 leading-relaxed">{{ highlightedPost.data.description }}</p>
      {% endif %}
      <div class="flex items-center gap-2 mt-1.5">
        <time class="meta-text text-[0.68rem] text-gray-400 dark:text-gray-500">{{ highlightedPost.date | readableDate }}</time>
        {% if highlightedPost.data.tags %}
          {% for tag in highlightedPost.data.tags | filterTagList | head(2) %}
            <span class="meta-text text-[0.65rem] px-1.5 py-0.5 rounded bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400">#{{ tag }}</span>
          {% endfor %}
        {% endif %}
        <span class="text-xs font-medium ml-auto transition-transform group-hover:translate-x-0.5" style="color: var(--accent-color);">Read →</span>
      </div>
    </a>
  </div>
  <hr class="mb-5 border-gray-200 dark:border-gray-800" />
{% endif %}

{# ── QUOTE OF THE DAY ──────────────────────────────────── #}
<div class="not-prose animate-enter stagger-2 mb-5">
  <blockquote id="qotd" class="border-l-2 pl-3 text-sm italic text-gray-700 dark:text-gray-300 leading-relaxed m-0" style="border-color: var(--accent-color);">{{ qotd.quote }}</blockquote>
  <p class="text-xs text-gray-400 dark:text-gray-500 mt-1.5 text-right m-0 italic" id="who">— {{ qotd.provider }}</p>
</div>

<script src="/static/js/typeit.min.js"></script>
<script>new TypeIt("#qotd", { speed: 25, waitUntilVisible: true }).go();</script>

<hr class="mb-5 border-gray-200 dark:border-gray-800" />

{# ── RECENT ACTIVITY ───────────────────────────────────── #}
<div class="not-prose animate-enter stagger-3" x-data="{ hView: localStorage.getItem('h-feed-view') || 'grid' }" x-init="$watch('hView', v => localStorage.setItem('h-feed-view', v))">
  <div class="flex items-center justify-between mb-3">
    <span class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">Recent</span>
    <div class="flex items-center gap-2">
      <div class="flex border border-gray-200 dark:border-gray-700 rounded overflow-hidden text-[0.65rem]">
        <button @click="hView = 'list'"
          :class="hView === 'list' ? 'bg-gray-100 dark:bg-gray-800' : 'hover:bg-gray-50 dark:hover:bg-gray-800/50'"
          class="px-2 py-1 transition-colors" title="List view">
          {% feather "list", class="w-3 h-3" %}
        </button>
        <button @click="hView = 'grid'"
          :class="hView === 'grid' ? 'bg-gray-100 dark:bg-gray-800' : 'hover:bg-gray-50 dark:hover:bg-gray-800/50'"
          class="px-2 py-1 transition-colors border-l border-gray-200 dark:border-gray-700" title="Grid view">
          {% feather "grid", class="w-3 h-3" %}
        </button>
      </div>
      <a href="{{ '/feed/' | url }}" class="text-xs font-medium" style="text-decoration: none; color: var(--accent-color);">All →</a>
    </div>
  </div>

  {% set feedItems = collections.feed | head(9) %}

  {# List view #}
  <ul x-show="hView === 'list'" x-cloak class="feed-list m-0 p-0 list-none">
    {% for item in feedItems %}
      {{ feedCard(item, { variant: 'list' }) }}
    {% endfor %}
  </ul>

  {# Grid view #}
  <div x-show="hView === 'grid'" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
    {% for item in feedItems %}
      {{ feedCard(item, { variant: 'full' }) }}
    {% endfor %}
  </div>
</div>
