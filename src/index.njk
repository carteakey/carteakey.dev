---
layout: layouts/home.njk
htmlTemplateEngine: "webc"
---
{% from "components/feed-card.njk" import feedCard %}

{# ── HERO ─────────────────────────────────────────────── #}
<div class="flex flex-col sm:flex-row gap-4 items-start not-prose animate-enter py-2">
  {% image "./src/static/img/headshot.png" , "me", "rounded-full w-14 h-14 shrink-0 object-cover ring-2 ring-gray-200 dark:ring-gray-700 mt-0.5" %}
  <div class="space-y-1">
    <p class="text-base font-semibold text-gray-900 dark:text-gray-100 m-0">
      Kartikey Chauhan <span class="font-normal text-gray-500 dark:text-gray-400">— data analyst, Toronto</span>
    </p>
    <p class="text-sm text-gray-600 dark:text-gray-400 m-0 leading-relaxed">
      I tinker with tech, build <a href="/portfolio" class="accent-link font-medium" style="text-decoration: none;">side projects</a>, and write about AI, linux, and data. This is where I put it all.
    </p>
    <div class="flex flex-wrap gap-3 pt-1 text-xs text-gray-500 dark:text-gray-400">
      <a href="/about" class="hover:text-gray-900 dark:hover:text-white transition-colors" style="text-decoration: none;">About</a>
      <span>·</span>
      <a href="/now" class="hover:text-gray-900 dark:hover:text-white transition-colors" style="text-decoration: none;">Now</a>
      <span>·</span>
      <a href="/cv" class="hover:text-gray-900 dark:hover:text-white transition-colors" style="text-decoration: none;">CV</a>
      <span>·</span>
      <a href="https://github.com/carteakey" class="hover:text-gray-900 dark:hover:text-white transition-colors" style="text-decoration: none;" target="_blank" rel="noopener">GitHub</a>
    </div>
  </div>
</div>

<hr class="my-5 border-gray-200 dark:border-gray-800" />

{# ── FEATURED POST ─────────────────────────────────────── #}
{% set highlightedPost = collections.featuredPost %}
{% if highlightedPost %}
  <div class="not-prose animate-enter stagger-1 mb-5">
    <div class="flex items-baseline gap-2 mb-2">
      <span class="meta-text text-[0.65rem] text-amber-600 dark:text-amber-500 uppercase tracking-wider font-semibold">★ Featured</span>
    </div>
    <a href="{{ highlightedPost.url }}" class="block group" style="text-decoration: none;">
      <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100 group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors leading-snug m-0">{{ highlightedPost.data.title }}</h2>
      {% if highlightedPost.data.description %}
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1 m-0 leading-relaxed">{{ highlightedPost.data.description }}</p>
      {% endif %}
      <div class="flex items-center gap-2 mt-1.5">
        <time class="meta-text text-[0.68rem] text-gray-400 dark:text-gray-500">{{ highlightedPost.date | readableDate }}</time>
        {% if highlightedPost.data.tags %}
          {% for tag in highlightedPost.data.tags | filterTagList | head(2) %}
            <span class="meta-text text-[0.65rem] px-1.5 py-0.5 rounded bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400">#{{ tag }}</span>
          {% endfor %}
        {% endif %}
        <span class="text-xs text-amber-600 dark:text-amber-500 ml-auto group-hover:translate-x-0.5 transition-transform">Read →</span>
      </div>
    </a>
  </div>
  <hr class="mb-5 border-gray-200 dark:border-gray-800" />
{% endif %}

{# ── QUOTE OF THE DAY ──────────────────────────────────── #}
<div class="not-prose animate-enter stagger-2 mb-5">
  <blockquote id="qotd" class="border-l-2 pl-3 text-sm italic text-gray-700 dark:text-gray-300 leading-relaxed m-0" style="border-color: var(--accent-color);">{{ qotd.quote }}</blockquote>
  <p class="text-xs text-gray-400 dark:text-gray-500 mt-1.5 text-right m-0 italic" id="who">— {{ qotd.provider }}</p>
</div>

<script src="/static/js/typeit.min.js"></script>
<script>new TypeIt("#qotd", { speed: 25, waitUntilVisible: true }).go();</script>

<hr class="mb-5 border-gray-200 dark:border-gray-800" />

{# ── RECENT ACTIVITY ───────────────────────────────────── #}
<div class="not-prose animate-enter stagger-3">
  <div class="flex items-center justify-between mb-3">
    <span class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">Recent</span>
    <a href="{{ '/feed/' | url }}" class="text-xs accent-link font-medium" style="text-decoration: none;">All activity →</a>
  </div>

  {% set feedItems = collections.feed | head(12) %}
  <ul class="feed-list m-0 p-0 list-none">
    {% for item in feedItems %}
      {{ feedCard(item, { variant: 'list' }) }}
    {% endfor %}
  </ul>

  <p class="text-xs text-gray-400 dark:text-gray-500 mt-4 m-0">
    Posts · <a href="{{ '/blog/' | url }}" class="hover:text-gray-700 dark:hover:text-gray-300 transition-colors" style="text-decoration: none;">Blog</a>
    &nbsp;·&nbsp; Code · <a href="{{ '/snippets/' | url }}" class="hover:text-gray-700 dark:hover:text-gray-300 transition-colors" style="text-decoration: none;">Snippets</a>
    &nbsp;·&nbsp; Everything else · <a href="{{ '/feed/' | url }}" class="hover:text-gray-700 dark:hover:text-gray-300 transition-colors" style="text-decoration: none;">Feed</a>
  </p>
</div>
