---
layout: layouts/home.njk
htmlTemplateEngine: "webc"
---
{% from "components/feed-card.njk" import feedCard %}

{% set highlightedPost = collections.featuredPost %}
{% set feedItems = collections.feed | head(6) %}
{% set popularPosts = (collections.popularPosts | default([])) | head(5) %}
{% set homeIndexItems = [
  {
    url: "/blog/",
    name: "Writing",
    count: collections.posts | length,
    note: "Long-form writing on data, local AI, self-hosting, systems, and the internet."
  },
  {
    url: "/notes/",
    name: "Notes",
    count: collections.notes | length,
    note: "Working thoughts, small logs, experiments, and ideas that are not done yet."
  },
  {
    url: "/projects/",
    name: "Projects",
    count: projects.projects | length,
    note: "Things I build, ship, abandon, and occasionally return to with better judgment."
  },
  {
    url: "/snippets/",
    name: "Snippets",
    count: collections.snippets | length,
    note: "A collection of useful code snippets and quick tips."
  },
  {
    url: "/feed/",
    name: "Feed",
    count: "Log",
    note: "A unified timeline of everything I publish on this site."
  },
  {
    url: "/quotations/",
    name: "Quotations",
    count: collections.quotations | length,
    note: "Borrowed clarity. Lines worth keeping around because they continue to explain things."
  }
] %}

<div class="home-index-shell not-prose">
  <section class="home-intro-grid animate-enter">
    <div class="home-intro-main">
      <div class="home-avatar-shell shrink-0">
        {% image "./src/static/img/headshot.png" , "Kartikey Chauhan", "w-full h-full object-cover" %}
      </div>

      <div>
        <p class="home-eyebrow">Toronto / data work / homelabs / local AI / internet archives</p>
        <h1 class="home-title">Hi, I’m <span class="home-title-accent">Kartikey.</span></h1>
        <p class="home-dek">
          Data analyst in Toronto. I write about data work, local AI, homelabs, personal systems, and the internet after it got strange.
        </p>
        <p class="home-dek home-dek-muted">
          Grab a coffee and look around.
        </p>

        <div class="home-link-row">
          <a href="/about">About</a>
          <a href="/now">Now</a>
          <a href="/projects">Projects</a>
          <a href="/cv">CV</a>
          <a href="/feed/">Feed</a>
          <a href="https://github.com/carteakey" target="_blank" rel="noopener">GitHub ↗</a>
        </div>
      </div>
    </div>

    <aside class="home-glance">
      <p class="home-glance-title">At A Glance</p>
      <div class="home-glance-row">
        <span class="home-glance-label">Posts</span>
        <span class="home-glance-value">{{ collections.posts | length }}</span>
      </div>
      <div class="home-glance-row">
        <span class="home-glance-label">Notes</span>
        <span class="home-glance-value">{{ collections.notes | length }}</span>
      </div>
      <div class="home-glance-row">
        <span class="home-glance-label">Projects</span>
        <span class="home-glance-value">{{ projects.projects | length }}</span>
      </div>
      <div class="home-glance-row">
        <span class="home-glance-label">TILs</span>
        <span class="home-glance-value">{{ collections.til | length }}</span>
      </div>
      <div class="home-glance-row">
        <span class="home-glance-label">Quotes Saved</span>
        <span class="home-glance-value">{{ collections.quotations | length }}</span>
      </div>
    </aside>
  </section>

  <section class="home-grid-two animate-enter stagger-1">
    {% if startHere and startHere.length %}
      <div>
        <div class="home-panel-head">
          <p class="home-panel-kicker">START HERE</p>
          <a href="/blog/" class="home-panel-link">All writing →</a>
        </div>

        <ul class="home-selected-list">
          {% for item in startHere %}
            <li class="home-selected-item">
              <a href="{{ item.url | url }}" class="home-selected-title">{{ item.title }}</a>
              {% if item.note %}
                <p class="home-selected-note">{{ item.note }}</p>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}

    <div>
      <div class="home-panel-head">
        <p class="home-panel-kicker">Site Index</p>
        <a href="/more/" class="home-panel-link">Full map →</a>
      </div>

      <div class="home-directory-grid">
        {% for item in homeIndexItems %}
          <a href="{{ item.url }}" class="home-directory-item">
            <span class="home-directory-name">{{ item.name }}</span>
            <span class="home-directory-count">{{ item.count }}</span>
            <span class="home-directory-note">{{ item.note }}</span>
          </a>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="home-grid-four animate-enter stagger-2">
    <div>
      <div class="home-panel-head">
        <p class="home-panel-kicker">Featured Writing</p>
        {% if highlightedPost %}
          <a href="{{ highlightedPost.url }}" class="home-panel-link">Read →</a>
        {% endif %}
      </div>

      {% if highlightedPost %}
        <article class="home-featured">
          <div>
            <h2 class="home-featured-title">
              <a href="{{ highlightedPost.url }}">{{ highlightedPost.data.title }}</a>
            </h2>
            {% if highlightedPost.data.description %}
              <p class="home-featured-description">{{ highlightedPost.data.description }}</p>
            {% endif %}

            <div class="home-featured-meta">
              <time class="badge badge-meta">{{ highlightedPost.date | readableDate }}</time>
              {% for tag in highlightedPost.data.tags | filterTagList | head(2) %}
                <span class="badge badge-tag">#{{ tag }}</span>
              {% endfor %}
            </div>
          </div>

          {% if highlightedPost.data.image %}
            <a href="{{ highlightedPost.url }}" class="home-featured-image" aria-label="{{ highlightedPost.data.title }}">
              <img src="{{ highlightedPost.data.image | url }}" alt="{{ highlightedPost.data.imageAlt or highlightedPost.data.title }}" loading="lazy" decoding="async" class="dark:invert dark:brightness-125">
            </a>
          {% endif %}
        </article>
      {% endif %}
    </div>

    <div>
      <div class="home-panel-head">
        <p class="home-panel-kicker">Recent Activity</p>
        <a href="/feed/" class="home-panel-link">All updates →</a>
      </div>

      <ul class="feed-list m-0 p-0 list-none">
        {% for item in feedItems %}
          {{ feedCard(item, { variant: 'list' }) }}
        {% endfor %}
      </ul>
    </div>

    <div>
      <div class="home-panel-head">
        <p class="home-panel-kicker">Quote Of The Day</p>
      </div>

      <blockquote class="home-quote">{{ qotd.quote }}</blockquote>
      <p class="home-quote-source">— {{ qotd.provider }}</p>
    </div>

    {% if popularPosts.length %}
      <div>
        <div class="home-panel-head">
          <p class="home-panel-kicker">Popular Posts</p>
          <a href="/feed/" class="home-panel-link">From readers →</a>
        </div>

        <ul class="home-popular-list">
          {% for entry in popularPosts %}
            <li class="home-popular-item">
              <div class="flex items-start gap-2">
                <span class="badge badge-tag">{{ entry.count }}▲</span>
                <a href="{{ entry.url }}" class="home-selected-title">{{ entry.title }}</a>
              </div>
            </li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}
  </section>
</div>
